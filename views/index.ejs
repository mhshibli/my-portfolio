                    <p class="text-gray-600 dark:text-gray-400 mb-4 text-sm"><%= p.description %></p>
                    <% if(p.link) { %> <a href="<%= p.link %>" target="_blank" class="text-blue-500 font-bold hover:underline">View →</a> <% } %>
                </div>
                <% }) %>
            </div>
        </section>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            <section id="education">
                <h2 class="text-2xl font-bold mb-8 border-l-4 border-purple-600 pl-3">Education</h2>
                <div class="space-y-4">
                    <% education.forEach(e => { %>
                    <div class="bg-white dark:bg-gray-800 p-5 rounded-xl border-l-4 border-purple-500 shadow-sm">
                        <h4 class="font-bold text-lg"><%= e.degree %></h4>
                        <p class="text-gray-500 text-sm"><%= e.institution %> | <%= e.year %></p>
                    </div>
                    <% }) %>
                </div>
            </section>

