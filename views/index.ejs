<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mahmudul Hasan | Portfolio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>tailwind.config = { darkMode: 'class' }</script>
   <style>
        html { scroll-behavior: smooth; }
        
        /* --- Deep Ash Theme (Eye-Care Light Mode) --- */
        .light body { 
            background-color: #cbd5e1; /* গাঢ় গ্রে/অ্যাশ ব্যাকগ্রাউন্ড */
            color: #0f172a; 
        }
        
        /* Floating Card Style for Light Mode */
        .light .section-card, .light .admin-card, .light .msg-card { 
            background-color: #f1f5f9; /* ধবধবে সাদার বদলে চোখের জন্য আরামদায়ক হালকা অ্যাশ-সাদা */
            border: 1px solid #94a3b8; /* বর্ডারটি একটু গাঢ় করা হয়েছে */
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1); 
            transition: all 0.3s ease;
        }
        .light .section-card:hover, .light .admin-card:hover { 
            transform: translateY(-4px); 
            box-shadow: 0 20px 35px -5px rgba(0, 0, 0, 0.15); 
        }

        /* ডার্ক মেনু বার */
        .main-nav { background-color: #1e293b !important; border-bottom: 1px solid #334155; }
        .main-nav .logo-text { color: #f8fafc !important; }
        .main-nav .nav-link { color: #94a3b8 !important; }
        
        /* Active Menu Style */
        .nav-link.active { color: #f97316 !important; font-weight: 800; }
        .md-active-border.active { border-bottom: 2px solid #f97316; }
        
        /* Mobile Menu */
        @media (max-width: 768px) {
            .nav-link.active { background-color: rgba(249, 115, 22, 0.1); border-left: 4px solid #f97316; padding-left: 1rem; }
            #mobile-menu { background-color: #1e293b !important; }
        }

        /* Message Modal Animation */
        #msg-modal { transition: opacity 0.3s ease; }
    </style>
</head>
<body class="dark:bg-gray-900 dark:text-gray-100 transition-colors duration-300 flex flex-col min-h-screen">

    <nav class="main-nav sticky top-0 z-50 backdrop-blur-md">
        <div class="container mx-auto px-4 py-4 flex items-center justify-between">
            <a href="#" class="logo-text text-2xl font-bold tracking-tighter uppercase">MAHMUDUL HASAN</a>
            
            <div id="desktop-menu" class="hidden md:flex items-center gap-6 font-semibold text-xs uppercase tracking-widest">
                <a href="#about" class="nav-link md-active-border hover:text-orange-500 transition px-1">About</a>
                <a href="#education" class="nav-link md-active-border hover:text-orange-500 transition px-1">Education</a>
                <a href="#projects" class="nav-link md-active-border hover:text-orange-500 transition px-1">Projects</a>
                <a href="#achievements" class="nav-link md-active-border hover:text-orange-500 transition px-1">Achievements</a>
                <a href="#gallery" class="nav-link md-active-border hover:text-orange-500 transition px-1">Gallery</a>
            </div>

            <div class="flex items-center gap-3">
                <button id="theme-toggle" class="p-2 rounded-xl bg-gray-700 text-yellow-400 shadow-inner"><span id="theme-icon">🌙</span></button>
                <button id="menu-btn" class="md:hidden p-2 text-white focus:outline-none"><i class="fas fa-bars text-2xl"></i></button>
            </div>
        </div>

        <div id="mobile-menu" class="hidden flex-col border-t border-gray-700 px-6 py-6 space-y-4 shadow-xl">
            <a href="#about" class="nav-link block font-medium py-2">About</a>
            <a href="#education" class="nav-link block font-medium py-2">Education</a>
            <a href="#projects" class="nav-link block font-medium py-2">Projects</a>
            <a href="#achievements" class="nav-link block font-medium py-2">Achievements</a>
            <a href="#gallery" class="nav-link block font-medium py-2">Gallery</a>
        </div>
    </nav>

    <main class="flex-grow container mx-auto px-4 py-12 space-y-32">
        
        <section id="about" class="section max-w-5xl mx-auto text-center py-10 scroll-mt-24">
            <h2 class="text-4xl font-black mb-8 uppercase tracking-tighter border-b-4 border-blue-600 inline-block text-gray-900 dark:text-white">About Me</h2>
            
            <div class="section-card dark:bg-gray-800 rounded-3xl mt-6 p-8 md:p-10 shadow-lg flex flex-col md:flex-row items-center gap-8">
                
                <div class="flex-shrink-0 group">
                    <img src="/images/profile.jpg" alt="Mahmudul Hasan" 
                         class="w-48 h-48 md:w-56 md:h-56 object-cover rounded-full border-4 border-white dark:border-gray-700 shadow-xl transition-transform duration-500 group-hover:scale-105 mx-auto">
                </div>

                <div class="italic text-xl text-gray-800 dark:text-gray-200 leading-relaxed text-center md:text-left">
                    "<%= aboutMe %>"
                </div>

            </div>
        </section>

        <section id="education" class="section scroll-mt-24">
            <h2 class="text-3xl font-black mb-10 border-l-8 border-purple-600 pl-4 uppercase text-gray-800 dark:text-white">Education</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% education.forEach(e => { %>
                <div class="section-card dark:bg-gray-800 p-8 rounded-3xl border-l-8 border-purple-500">
                    <h4 class="font-bold text-2xl mb-2 text-purple-700 dark:text-purple-400"><%= e.degree %></h4>
                    <p class="text-gray-700 dark:text-gray-300 font-semibold"><%= e.institution %> • <%= e.year %></p>
                </div>
                <% }) %>
            </div>
        </section>

        <section id="projects" class="section scroll-mt-24">
            <h2 class="text-3xl font-black mb-10 border-l-8 border-blue-600 pl-4 uppercase text-gray-800 dark:text-white">Projects & Work</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% projects.forEach(p => { %>
                <div class="section-card dark:bg-gray-800 p-8 rounded-3xl border-t-4 border-blue-500 shadow-md hover:shadow-2xl transition">
                    <h3 class="text-2xl font-bold mb-3 text-blue-600 dark:text-blue-400 uppercase tracking-tighter"><%= p.title %></h3>
                    <p class="text-gray-700 dark:text-gray-300 text-sm leading-relaxed"><%= p.description %></p>
                </div>
                <% }) %>
            </div>
        </section>

        <section id="achievements" class="section scroll-mt-24">
            <h2 class="text-3xl font-black mb-10 border-l-8 border-green-600 pl-4 uppercase text-gray-800 dark:text-white">Achievements</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% achievements.forEach(a => { %>
                <div class="section-card dark:bg-gray-800 p-6 rounded-2xl border-r-8 border-green-500 flex items-center justify-between">
                    <span class="font-bold text-sm text-gray-800 dark:text-gray-200"><%= a.title %></span>
                    <i class="fas fa-award text-green-500 text-xl"></i>
                </div>
                <% }) %>
            </div>
        </section>

        <section id="gallery" class="section scroll-mt-24 pb-20">
            <div class="flex justify-between items-center mb-10 border-l-8 border-orange-500 pl-4">
                <h2 class="text-3xl font-black uppercase text-gray-800 dark:text-white">Photo Gallery</h2>
                <button onclick="toggleGalleryModal()" class="bg-orange-500 text-white px-6 py-2 rounded-full font-bold shadow-lg hover:bg-orange-600 transition">SEE MORE</button>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <% gallery.slice(0, 4).forEach(img => { %>
                <div class="relative group overflow-hidden rounded-2xl aspect-square shadow-xl cursor-pointer border-4 border-white dark:border-gray-700" onclick="toggleGalleryModal()">
                    <img src="<%= img.image_url %>" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                </div>
                <% }) %>
            </div>
        </section>

        <section id="contact" class="scroll-mt-24 pb-20 section">
            <div class="text-center mb-10">
                <h2 class="text-3xl font-black uppercase inline-block border-b-4 border-blue-600 pb-2 text-gray-800 dark:text-white">Send Me a Message</h2>
            </div>
            <div class="max-w-3xl mx-auto section-card dark:bg-gray-800 p-8 rounded-3xl shadow-2xl border-t-8 border-blue-500">
                <form action="/send-message" method="POST" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <input type="text" name="name" placeholder="Name" required class="w-full p-4 rounded-xl border border-gray-200 dark:bg-gray-900 dark:border-gray-700 outline-none focus:border-blue-500 transition text-gray-900 dark:text-white">
                        <input type="email" name="email" placeholder="Email" required class="w-full p-4 rounded-xl border border-gray-200 dark:bg-gray-900 dark:border-gray-700 outline-none focus:border-blue-500 transition text-gray-900 dark:text-white">
                    </div>
                    <textarea name="message" rows="5" placeholder="Message" required class="w-full p-4 rounded-xl border border-gray-200 dark:bg-gray-900 dark:border-gray-700 outline-none focus:border-blue-500 transition text-gray-900 dark:text-white"></textarea>
                    <button type="submit" class="w-full bg-blue-600 text-white font-black py-4 rounded-xl uppercase tracking-widest shadow-lg hover:bg-blue-700 transition">Send Message</button>
                </form>
            </div>
        </section>
    </main>

    <footer class="bg-gray-800 text-gray-300 py-12 text-center mt-auto">
        <div class="flex justify-center gap-8 mb-8 text-2xl">
            <a href="https://www.facebook.com/mahmudulhasan.shibli.5" class="hover:text-blue-500"><i class="fab fa-facebook"></i></a>
            <a href="https://github.com/mhshibli"><i class="fab fa-github"></i></a>
            <a href="https://www.instagram.com/shibli__mahmud/" class="hover:text-pink-500"><i class="fab fa-instagram"></i></a>
            <a href="https://www.linkedin.com/in/mahmudul-hasan-0730a1211/" class="hover:text-blue-400"><i class="fab fa-linkedin"></i></a>
        </div>
        <p class="text-xs font-bold uppercase tracking-widest text-gray-400">&copy; 2026 Mahmudul Hasan. All Rights Reserved.</p>
    </footer>

    <div id="all-photos-modal" class="fixed inset-0 bg-white/95 dark:bg-gray-900/95 z-[100] hidden flex-col overflow-y-auto backdrop-blur-md">
        <div class="sticky top-0 p-6 border-b dark:border-gray-700 flex justify-between items-center">
            <h2 class="text-xl font-black text-orange-500 uppercase">Gallery Viewer</h2>
            <button onclick="toggleGalleryModal()" class="text-red-500 text-3xl"><i class="fas fa-times-circle"></i></button>
        </div>
        <div class="container mx-auto p-6 grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4">
            <% gallery.forEach(img => { %>
            <div class="cursor-pointer rounded-xl overflow-hidden border-4 border-white dark:border-gray-700 shadow-lg aspect-square shadow-md" onclick="showFullImage('<%= img.image_url %>', '<%= img.caption %>', '<%= img.description %>')">
                <img src="<%= img.image_url %>" class="w-full h-full object-cover">
            </div>
            <% }) %>
        </div>
    </div>

    <div id="full-image-overlay" class="fixed inset-0 bg-black/90 z-[200] hidden items-center justify-center p-4" onclick="this.classList.replace('flex','hidden')">
        <div class="max-w-4xl w-full bg-white dark:bg-gray-800 rounded-3xl overflow-hidden shadow-2xl" onclick="event.stopPropagation()">
            <img id="display-img" src="" class="w-full max-h-[65vh] object-contain bg-black">
            <div class="p-8 text-center"><h3 id="display-title" class="text-2xl font-bold text-blue-600 mb-2"></h3><p id="display-desc" class="text-gray-700 dark:text-gray-300 text-lg"></p></div>
        </div>
    </div>

    <script>
        // ১. Scroll Active Logic (100% Fixed for All Sections)
        const sections = document.querySelectorAll('section[id]');
        const navLinks = document.querySelectorAll('.nav-link');

        window.addEventListener('scroll', () => {
            let current = '';
            const scrollY = window.pageYOffset;

            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                // ২৫০ পিক্সেল অফসেট রাখা হয়েছে যাতে সেকশনে ঢোকার সাথে সাথেই মেনু চেঞ্জ হয়
                if (scrollY >= sectionTop - 250) {
                    current = section.getAttribute('id');
                }
            });

            navLinks.forEach(link => {
                link.classList.remove('active');
                // ডেস্কটপ এবং মোবাইল উভয় মেনুর লিংকেই কমলা কালার অ্যাপ্লাই হবে
                if (link.getAttribute('href') === `#${current}`) {
                    link.classList.add('active');
                }
            });
        });

        // ২. Mobile Menu Toggle
        const menuBtn = document.getElementById('menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        menuBtn.onclick = () => mobileMenu.classList.toggle('hidden');
        document.querySelectorAll('#mobile-menu a').forEach(l => l.onclick = () => mobileMenu.classList.add('hidden'));

        // ৩. Theme Toggle (Dark/Light Mode)
        const themeBtn = document.getElementById('theme-toggle'), themeIcon = document.getElementById('theme-icon'), html = document.documentElement;
        if(localStorage.theme === 'dark') { html.classList.add('dark'); themeIcon.innerText = '☀️'; }
        themeBtn.onclick = () => {
            html.classList.toggle('dark'); const isD = html.classList.contains('dark');
            localStorage.theme = isD ? 'dark' : 'light'; themeIcon.innerText = isD ? '☀️' : '🌙';
        }

        // ৪. Gallery Modals
        function toggleGalleryModal() { 
            const m = document.getElementById('all-photos-modal'); 
            m.classList.toggle('hidden'); 
            m.classList.toggle('flex'); 
        }
        function showFullImage(u, t, d) {
            document.getElementById('display-img').src = u;
            document.getElementById('display-title').innerText = t;
            document.getElementById('display-desc').innerText = d || "";
            document.getElementById('full-image-overlay').classList.replace('hidden', 'flex');
        }
    </script>
</body>
</html>
