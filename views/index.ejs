                        <h4 class="font-bold text-lg"><%= a.title %></h4>
                        <p class="text-gray-500 text-sm">Issued/Received: <%= a.year %></p>
                    </div>
                    <% }) %>
                </div>
            </section>
        </div>
    </div>

