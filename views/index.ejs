<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mahmudul Hasan | Portfolio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>tailwind.config = { darkMode: 'class' }</script>
    <style>
        html { scroll-behavior: smooth; }
        .nav-link.active { color: #f97316 !important; font-weight: 800; border-bottom: 2px solid #f97316; }
        .social-link { transition: all 0.3s ease; }
        .social-link:hover { transform: translateY(-5px); color: #f97316; }
    </style>
</head>
<body class="bg-gray-50 text-gray-900 dark:bg-gray-900 dark:text-gray-100 transition-colors duration-300 flex flex-col min-h-screen">

    <nav class="bg-white/90 dark:bg-gray-800/90 backdrop-blur-md sticky top-0 z-50 border-b dark:border-gray-700">
        <div class="container mx-auto px-4 py-4 flex items-center justify-between">
            <a href="#" class="text-2xl font-bold text-blue-600 dark:text-blue-400 uppercase">MAHMUDUL</a>
            <div id="desktop-menu" class="hidden md:flex items-center gap-6 font-semibold text-xs uppercase tracking-widest text-gray-500">
                <a href="#about" class="nav-link px-1">About</a>
                <a href="#education" class="nav-link px-1">Education</a>
                <a href="#projects" class="nav-link px-1">Projects</a>
                <a href="#achievements" class="nav-link px-1">Achievements</a>
                <a href="#gallery" class="nav-link px-1">Gallery</a>
            </div>
            <div class="flex items-center gap-3">
                <button id="theme-toggle" class="p-2 rounded-xl bg-gray-100 dark:bg-gray-700">🌙</button>
                <button id="menu-btn" class="md:hidden p-2"><i class="fas fa-bars text-2xl"></i></button>
            </div>
        </div>
        <div id="mobile-menu" class="hidden flex-col bg-white dark:bg-gray-800 p-6 space-y-4 shadow-xl">
            <a href="#about" class="nav-link">About Me</a>
            <a href="#education" class="nav-link">Education</a>
            <a href="#projects" class="nav-link">Projects</a>
            <a href="#gallery" class="nav-link">Gallery</a>
        </div>
    </nav>

    <main class="flex-grow container mx-auto px-4 py-12 space-y-32">
        <section id="about" class="max-w-4xl mx-auto text-center py-10 section">
            <h2 class="text-4xl font-black mb-8 uppercase border-b-4 border-blue-600 inline-block">About Me</h2>
            <div class="p-8 bg-white dark:bg-gray-800 rounded-3xl shadow-sm border dark:border-gray-700 mt-6 italic text-xl">
                "<%= aboutMe %>"
            </div>
        </section>

        <section id="education" class="section">
            <h2 class="text-3xl font-bold mb-10 border-l-8 border-purple-600 pl-4 uppercase">Education</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% education.forEach(e => { %>
                <div class="bg-white dark:bg-gray-800 p-8 rounded-3xl border-l-8 border-purple-500 shadow-sm">
                    <h4 class="font-bold text-2xl mb-2"><%= e.degree %></h4>
                    <p><%= e.institution %> • <%= e.year %></p>
                </div>
                <% }) %>
            </div>
        </section>

        <section id="projects" class="section">
            <h2 class="text-3xl font-bold mb-10 border-l-8 border-blue-600 pl-4 uppercase">Projects & Work</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% projects.forEach(p => { %>
                <div class="bg-white dark:bg-gray-800 p-8 rounded-3xl shadow-sm border dark:border-gray-700">
                    <h3 class="text-2xl font-bold mb-3 text-blue-600"><%= p.title %></h3>
                    <p class="text-sm"><%= p.description %></p>
                </div>
                <% }) %>
            </div>
        </section>

        <section id="achievements" class="section text-sm">
            <h2 class="text-3xl font-bold mb-10 border-l-8 border-green-600 pl-4 uppercase">Achievements</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <% achievements.forEach(a => { %>
                <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border-l-8 border-green-500 shadow-sm flex justify-between items-center font-bold">
                    <span><%= a.title %></span><i class="fas fa-award text-green-500 text-xl"></i>
                </div>
                <% }) %>
            </div>
        </section>

        <section id="gallery" class="section">
            <div class="flex justify-between items-center mb-10 border-l-8 border-orange-500 pl-4">
                <h2 class="text-3xl font-bold uppercase">Gallery</h2>
                <button onclick="toggleGalleryModal()" class="bg-orange-500 text-white px-6 py-2 rounded-full font-bold">SEE MORE</button>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <% gallery.slice(0, 4).forEach(img => { %>
                <div class="rounded-2xl overflow-hidden aspect-square shadow-md cursor-pointer" onclick="toggleGalleryModal()">
                    <img src="<%= img.image_url %>" class="w-full h-full object-cover">
                </div>
                <% }) %>
            </div>
        </section>

        <section id="contact" class="pb-20">
            <div class="text-center mb-10">
                <h2 class="text-3xl font-black uppercase inline-block border-b-4 border-blue-600 pb-2">Send Me a Message</h2>
            </div>
            <div class="max-w-3xl mx-auto bg-white dark:bg-gray-800 p-8 rounded-3xl shadow-xl border dark:border-gray-700">
                <form action="/send-message" method="POST" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <input type="text" name="name" placeholder="Your Name" required class="p-4 rounded-xl border dark:bg-gray-900 dark:border-gray-700 outline-none">
                        <input type="email" name="email" placeholder="Your Email" required class="p-4 rounded-xl border dark:bg-gray-900 dark:border-gray-700 outline-none">
                    </div>
                    <textarea name="message" rows="4" placeholder="Your Message" required class="w-full p-4 rounded-xl border dark:bg-gray-900 dark:border-gray-700 outline-none"></textarea>
                    <button type="submit" class="w-full bg-blue-600 text-white font-black py-4 rounded-xl uppercase tracking-widest">Send Message</button>
                </form>
            </div>
        </section>
    </main>

    <div id="all-photos-modal" class="fixed inset-0 bg-white dark:bg-gray-900 z-[100] hidden flex-col overflow-y-auto">
        <div class="sticky top-0 bg-white/90 dark:bg-gray-900/90 p-6 border-b flex justify-between items-center">
            <h2 class="text-orange-500 font-black uppercase tracking-widest">Gallery</h2>
            <button onclick="toggleGalleryModal()" class="text-red-500 text-3xl"><i class="fas fa-times-circle"></i></button>
        </div>
        <div class="container mx-auto p-6 grid grid-cols-2 md:grid-cols-5 gap-4">
            <% gallery.forEach(img => { %>
            <div class="cursor-pointer rounded-xl overflow-hidden aspect-square border dark:border-gray-700" onclick="showFullImage('<%= img.image_url %>', '<%= img.caption %>', '<%= img.description %>')">
                <img src="<%= img.image_url %>" class="w-full h-full object-cover">
            </div>
            <% }) %>
        </div>
    </div>

    <div id="full-image-overlay" class="fixed inset-0 bg-black/95 z-[200] hidden items-center justify-center p-4" onclick="this.classList.replace('flex','hidden')">
        <div class="max-w-4xl w-full bg-white dark:bg-gray-800 rounded-3xl overflow-hidden" onclick="event.stopPropagation()">
            <img id="display-img" src="" class="w-full max-h-[60vh] object-contain bg-black">
            <div class="p-8">
                <h3 id="display-title" class="text-2xl font-bold text-blue-600 mb-2"></h3>
                <p id="display-desc" class="text-gray-600 dark:text-gray-400"></p>
                <button onclick="document.getElementById('full-image-overlay').classList.replace('flex','hidden')" class="mt-4 text-red-500 font-bold uppercase">Close</button>
            </div>
        </div>
    </div>

    <footer class="bg-white dark:bg-gray-800 border-t dark:border-gray-700 py-12 text-center mt-auto">
        <div class="flex justify-center gap-8 mb-8 text-3xl text-gray-400">
            <a href="#" target="_blank" class="social-link"><i class="fab fa-facebook"></i></a>
            <a href="https://github.com/mhshibli" target="_blank" class="social-link"><i class="fab fa-github"></i></a>
            <a href="#" target="_blank" class="social-link"><i class="fab fa-instagram"></i></a>
            <a href="#" target="_blank" class="social-link"><i class="fab fa-linkedin"></i></a>
        </div>
        <p class="font-bold text-xs uppercase tracking-widest text-gray-400">&copy; <span id="year"></span> Mahmudul Hasan</p>
    </footer>

    <script>
        document.getElementById('year').innerText = new Date().getFullYear();
        const navLinks = document.querySelectorAll('.nav-link'), sections = document.querySelectorAll('.section');
        window.addEventListener('scroll', () => {
            let current = "";
            sections.forEach(s => { if (pageYOffset >= s.offsetTop - 150) current = s.getAttribute('id'); });
            navLinks.forEach(l => { l.classList.remove('active'); if (l.getAttribute('href').includes(current)) l.classList.add('active'); });
        });
        const themeBtn = document.getElementById('theme-toggle'), html = document.documentElement;
        if(localStorage.theme === 'dark') html.classList.add('dark');
        themeBtn.onclick = () => { html.classList.toggle('dark'); localStorage.theme = html.classList.contains('dark') ? 'dark' : 'light'; }
        document.getElementById('menu-btn').onclick = () => document.getElementById('mobile-menu').classList.toggle('hidden');
        function toggleGalleryModal() { const m = document.getElementById('all-photos-modal'); m.classList.toggle('hidden'); m.classList.toggle('flex'); }
        function showFullImage(u, t, d) {
            document.getElementById('display-img').src = u; document.getElementById('display-title').innerText = t;
            document.getElementById('display-desc').innerText = d || "";
            document.getElementById('full-image-overlay').classList.replace('hidden', 'flex');
        }
    </script>
</body>
</html>
