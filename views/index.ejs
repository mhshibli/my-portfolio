            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% projects.forEach(p => { %>
                <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-all">
                    <h3 class="text-xl font-bold mb-2 text-blue-600 dark:text-blue-400"><%= p.title %></h3>
