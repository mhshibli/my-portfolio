<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center h-screen font-sans">
    <div class="bg-white p-8 rounded-2xl shadow-xl w-96 border-t-4 border-blue-600">
        <h2 class="text-3xl font-bold mb-6 text-center text-gray-800 italic">Portfolio Login</h2>
        
        <% if (error) { %>
            <div class="bg-red-100 text-red-600 p-3 rounded-lg mb-4 text-center text-sm font-medium">
                <%= error %>
            </div>
        <% } %>

        <form action="/login" method="POST" class="flex flex-col gap-4">
            <div>
                <label class="text-xs font-bold text-gray-500 uppercase ml-1">Username</label>
                <input type="text" name="username" placeholder="Enter Username" required class="w-full p-3 border rounded-xl focus:outline-blue-500 transition-all">
            </div>
            <div>
                <label class="text-xs font-bold text-gray-500 uppercase ml-1">Password</label>
                <input type="password" name="password" placeholder="Enter Password" required class="w-full p-3 border rounded-xl focus:outline-blue-500 transition-all">
            </div>
            <button type="submit" class="bg-blue-600 text-white py-3 rounded-xl font-bold text-lg hover:bg-blue-700 shadow-lg transition-transform active:scale-95 mt-2">Login Now</button>
        </form>

        <div class="mt-6 text-center">
            <a href="/forgot-password" class="text-sm text-blue-500 hover:text-blue-700 hover:underline transition">Forgot Password?</a>
        </div>
        
        <div class="mt-4 border-t pt-4">
            <a href="/" class="block text-center text-gray-400 text-sm hover:text-gray-600">← Back to Portfolio Site</a>
        </div>
    </div>
</body>
</html>
