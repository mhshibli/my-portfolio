<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center h-screen">
    <div class="bg-white p-8 rounded-xl shadow-lg w-96 border-t-4 border-red-500">
        <h2 class="text-2xl font-bold mb-4 text-center">Reset Password</h2>
        <% if (error) { %> <p class="text-red-500 text-sm mb-4 text-center"><%= error %></p> <% } %>
        <form action="/forgot-password" method="POST" class="flex flex-col gap-4">
            <div>
                <label class="text-xs font-bold text-gray-500 uppercase">Your Secret Code</label>
                <input type="text" name="secret_answer" placeholder="Enter Secret Answer" required class="w-full p-3 border rounded-lg focus:outline-red-400">
            </div>
            <div>
                <label class="text-xs font-bold text-gray-500 uppercase">New Password</label>
                <input type="password" name="new_password" placeholder="Enter New Password" required class="w-full p-3 border rounded-lg focus:outline-red-400">
            </div>
            <button type="submit" class="bg-red-500 text-white py-3 rounded-lg font-bold hover:bg-red-600">Reset Password</button>
        </form>
        <a href="/login" class="block text-center mt-4 text-sm text-gray-500">Back to Login</a>
    </div>
</body>
</html>