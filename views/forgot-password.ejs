<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center h-screen font-sans">
    <div class="bg-white p-8 rounded-2xl shadow-xl w-96 border-t-4 border-orange-500">
        <h2 class="text-2xl font-bold mb-2 text-center text-gray-800">Reset Credentials</h2>
        <p class="text-xs text-gray-500 text-center mb-6 italic">Enter your secret code to reset password</p>
        
        <% if (error) { %>
            <div class="bg-red-100 text-red-600 p-3 rounded-lg mb-4 text-center text-sm">
                <%= error %>
            </div>
        <% } %>

        <form action="/forgot-password" method="POST" class="flex flex-col gap-5">
            <div>
                <label class="text-xs font-bold text-gray-500 uppercase ml-1">Security Answer/Code</label>
                <input type="text" name="secret_answer" placeholder="Enter Your Secret Code" required class="w-full p-3 border rounded-xl focus:outline-orange-500">
            </div>
            <div>
                <label class="text-xs font-bold text-gray-500 uppercase ml-1">Set New Password</label>
                <input type="password" name="new_password" placeholder="New Password" required class="w-full p-3 border rounded-xl focus:outline-orange-500">
            </div>
            <button type="submit" class="bg-orange-500 text-white py-3 rounded-xl font-bold text-lg hover:bg-orange-600 shadow-md transition-all active:scale-95">Update Password</button>
        </form>

        <div class="mt-6 text-center">
            <a href="/login" class="text-sm text-gray-400 hover:text-gray-600 transition">Remember it? Login</a>
        </div>
    </div>
</body>
</html>
