<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel | Mahmudul Hasan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>tailwind.config = { darkMode: 'class' }</script>
</head>
<body class="bg-gray-100 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen transition-colors duration-300">
    
    <nav class="bg-white dark:bg-gray-800 shadow p-4 sticky top-0 z-50 flex justify-between items-center border-b dark:border-gray-700">
        <h1 class="text-xl font-bold text-blue-600 uppercase">ADMIN DASHBOARD</h1>
        <div class="flex items-center gap-4">
            <button id="theme-toggle" class="p-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition">
                <span id="theme-icon">🌙</span>
            </button>
            <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg font-bold text-sm">Logout</a>
        </div>
    </nav>

    <div class="container mx-auto p-4 md:p-6 space-y-10">
        
        <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-sm border dark:border-gray-700">
            <h2 class="font-black mb-4 uppercase text-blue-600">Edit About Me / Bio</h2>
            <form action="/admin/update-about" method="POST" class="space-y-4">
                <textarea name="content" rows="4" class="w-full p-4 border rounded-xl dark:bg-gray-900 dark:border-gray-700" required><%= aboutMe %></textarea>
                <button type="submit" class="bg-blue-600 text-white px-8 py-3 rounded-xl font-bold shadow-md hover:bg-blue-700 transition">Update Bio</button>
            </form>
        </section>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-sm border dark:border-gray-700">
                <h2 class="font-bold mb-4 text-purple-600 uppercase">Manage Education</h2>
                <form action="/admin/add-education" method="POST" class="flex flex-col gap-2 mb-6">
                    <input type="text" name="degree" placeholder="Degree" required class="p-2 border rounded dark:bg-gray-900 dark:border-gray-700">
                    <input type="text" name="institution" placeholder="Institution" required class="p-2 border rounded dark:bg-gray-900 dark:border-gray-700">
                    <input type="text" name="year" placeholder="Year" required class="p-2 border rounded dark:bg-gray-900 dark:border-gray-700">
                    <button type="submit" class="bg-purple-600 text-white py-2 rounded-xl font-bold uppercase text-xs">Add Education</button>
                </form>
                <div class="space-y-2 max-h-48 overflow-y-auto pr-2">
                    <% education.forEach(e => { %>
                    <div class="flex justify-between items-center p-3 border dark:border-gray-700 rounded-lg">
                        <span class="text-xs font-bold"><%= e.degree %></span>
                        <form action="/admin/delete-education/<%= e.id %>" method="POST"><button class="text-red-400 hover:text-red-600"><i class="fas fa-trash"></i></button></form>
                    </div>
                    <% }) %>
                </div>
            </section>

            <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-sm border dark:border-gray-700">
                <h2 class="font-bold mb-4 text-blue-600 uppercase">Manage Projects & Work</h2>
                <form action="/admin/add-project" method="POST" class="flex flex-col gap-2 mb-6">
                    <input type="text" name="title" placeholder="Project Name" required class="p-2 border rounded dark:bg-gray-900 dark:border-gray-700">
                    <textarea name="description" placeholder="Description" class="p-2 border rounded dark:bg-gray-900 dark:border-gray-700 text-sm"></textarea>
                    <button type="submit" class="bg-blue-500 text-white py-2 rounded-xl font-bold uppercase text-xs">Add Project</button>
                </form>
                <div class="space-y-2 max-h-48 overflow-y-auto pr-2">
                    <% projects.forEach(p => { %>
                    <div class="flex justify-between items-center p-3 border dark:border-gray-700 rounded-lg">
                        <span class="text-xs font-bold"><%= p.title %></span>
                        <form action="/admin/delete-project/<%= p.id %>" method="POST"><button class="text-red-400 hover:text-red-600"><i class="fas fa-trash"></i></button></form>
                    </div>
                    <% }) %>
                </div>
            </section>
        </div>

        <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-sm border dark:border-gray-700">
            <h2 class="font-black text-green-600 mb-4 uppercase">Manage Achievements & Certifications</h2>
            <form action="/admin/add-achievement" method="POST" class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-6">
                <input type="text" name="title" placeholder="Achievement Name" required class="p-2 border rounded dark:bg-gray-900 dark:border-gray-700">
                <input type="text" name="year" placeholder="Year" required class="p-2 border rounded dark:bg-gray-900 dark:border-gray-700">
                <button type="submit" class="bg-green-600 text-white py-2 rounded-xl font-bold uppercase text-xs">Add Achievement</button>
            </form>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-2">
                <% achievements.forEach(a => { %>
                <div class="flex justify-between items-center p-3 border dark:border-gray-700 rounded-xl">
                    <span class="text-xs font-bold"><%= a.title %></span>
                    <form action="/admin/delete-achievement/<%= a.id %>" method="POST"><button class="text-red-400 hover:text-red-600"><i class="fas fa-trash"></i></button></form>
                </div>
                <% }) %>
            </div>
        </section>

        <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-sm border dark:border-gray-700">
            <h2 class="font-black text-orange-500 mb-6 uppercase border-b pb-2">Photo Gallery Management</h2>
            <form action="/admin/upload-photo" method="POST" enctype="multipart/form-data" class="bg-gray-50 dark:bg-gray-700 p-6 rounded-2xl space-y-4 mb-10 border-2 border-dashed dark:border-gray-600">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <input type="file" name="imageFile" required class="p-2 border rounded bg-white dark:bg-gray-900">
                    <input type="text" name="caption" placeholder="Photo Caption" required class="p-2 border rounded dark:bg-gray-900">
                </div>
                <textarea name="description" placeholder="Photo Details/Description" class="w-full p-2 border rounded dark:bg-gray-900" rows="3"></textarea>
                <button type="submit" class="w-full bg-orange-500 text-white py-3 rounded-xl font-bold uppercase tracking-widest shadow-md">Upload Photo</button>
            </form>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 max-h-[500px] overflow-y-auto pr-2">
                <% gallery.forEach(img => { %>
                <div class="flex gap-4 p-4 border dark:border-gray-700 rounded-2xl bg-white dark:bg-gray-900/50 shadow-sm">
                    <img src="<%= img.image_url %>" class="w-20 h-20 object-cover rounded-xl border dark:border-gray-700">
                    <form action="/admin/update-photo/<%= img.id %>" method="POST" class="flex-grow space-y-1">
                        <input type="text" name="caption" value="<%= img.caption %>" class="w-full text-xs font-bold p-1 border rounded dark:bg-gray-900">
                        <div class="flex justify-between items-center pt-1">
                            <button type="submit" class="bg-blue-600 text-white text-[10px] px-2 py-1 rounded">Update</button>
                            <button type="submit" formaction="/admin/delete-photo/<%= img.id %>" class="text-red-500 text-[10px] px-2 py-1 rounded border border-red-200">Delete</button>
                        </div>
                    </form>
                </div>
                <% }) %>
            </div>
        </section>

    </div>

    <script>
        const themeBtn = document.getElementById('theme-toggle'), themeIcon = document.getElementById('theme-icon'), html = document.documentElement;
        if(localStorage.theme === 'dark') { html.classList.add('dark'); themeIcon.innerText = '☀️'; }
        themeBtn.onclick = () => {
            html.classList.toggle('dark'); const isD = html.classList.contains('dark');
            localStorage.theme = isD ? 'dark' : 'light'; themeIcon.innerText = isD ? '☀️' : '🌙';
        }
    </script>
</body>
</html>
