<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel | Mahmudul Hasan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>tailwind.config = { darkMode: 'class' }</script>
</head>
<body class="bg-gray-100 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen transition-colors duration-300">

    <nav class="bg-white/80 dark:bg-gray-800/80 backdrop-blur-md shadow p-4 sticky top-0 z-50 flex justify-between items-center">
        <h1 class="text-xl font-bold text-blue-600 italic uppercase tracking-tighter">MAHMUDUL ADMIN</h1>
        <div class="flex items-center gap-3">
            <button id="theme-toggle" class="p-2 rounded-lg bg-gray-200 dark:bg-gray-700">
                <span id="theme-icon">🌙</span>
            </button>
            <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg font-bold text-sm">Logout</a>
        </div>
    </nav>

    <div class="container mx-auto p-4 md:p-6 space-y-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm text-center border dark:border-gray-700">
                <p class="text-xs text-gray-500 uppercase font-bold">Visitors</p>
                <h3 id="visitor-val" class="text-2xl font-black text-purple-600">0</h3>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm text-center border dark:border-gray-700">
                <p class="text-xs text-gray-500 uppercase font-bold">CPU Load</p>
                <h3 id="cpu-val" class="text-2xl font-black text-blue-600">--</h3>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm text-center border dark:border-gray-700">
                <p class="text-xs text-gray-500 uppercase font-bold">RAM Status</p>
                <h3 id="ram-val" class="text-2xl font-black text-green-600">--</h3>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm text-center border dark:border-gray-700">
                <p class="text-xs text-gray-500 uppercase font-bold">System Load</p>
                <h3 id="load-val" class="text-2xl font-black text-orange-600">--</h3>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <section class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border dark:border-gray-700">
                <h2 class="font-black text-orange-500 mb-4 uppercase">Upload Photo (Storage)</h2>
                <form action="/admin/upload-photo" method="POST" enctype="multipart/form-data" class="bg-gray-50 dark:bg-gray-700 p-4 rounded-xl space-y-4 mb-6">
                    <div>
                        <label class="text-xs font-bold text-gray-400 mb-1 block">SELECT FILE</label>
                        <input type="file" name="imageFile" accept="image/*" required class="w-full text-sm border p-2 rounded dark:bg-gray-800">
                    </div>
                    <input type="text" name="caption" placeholder="Enter Caption" class="w-full p-2 border rounded dark:bg-gray-800">
                    <button type="submit" class="w-full bg-orange-500 text-white py-3 rounded-xl font-bold hover:shadow-lg transition">UPLOAD NOW</button>
                </form>

                <div class="grid grid-cols-3 gap-3 max-h-60 overflow-y-auto pr-2">
                    <% gallery.forEach(img => { %>
                    <div class="relative group">
                        <img src="<%= img.image_url %>" class="w-full h-24 object-cover rounded-lg">
                        <form action="/admin/delete-photo/<%= img.id %>" method="POST" class="absolute top-1 right-1">
                            <button class="bg-red-500 text-white p-1 rounded-full text-[10px]"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                    <% }) %>
                </div>
            </section>

            <section class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border dark:border-gray-700">
                <h2 class="font-black mb-4 uppercase">Update Bio</h2>
                <form action="/admin/update-about" method="POST" class="space-y-4">
                    <textarea name="content" rows="6" class="w-full p-4 border rounded-xl dark:bg-gray-800" required><%= aboutMe %></textarea>
                    <button type="submit" class="w-full bg-blue-600 text-white py-3 rounded-xl font-bold">Save About Content</button>
                </form>
            </section>

            <section class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border dark:border-gray-700">
                <h2 class="font-black text-blue-600 mb-4 uppercase">Projects Management</h2>
                <form action="/admin/add-project" method="POST" class="flex gap-2 mb-4">
                    <input type="text" name="title" placeholder="Project Name" required class="flex-grow p-2 border rounded dark:bg-gray-800">
                    <button type="submit" class="bg-blue-500 text-white px-4 rounded-lg font-bold">+</button>
                </form>
                <div class="space-y-2 max-h-60 overflow-y-auto">
                    <% projects.forEach(p => { %>
                    <div class="flex justify-between items-center p-3 border dark:border-gray-700 rounded-lg">
                        <span class="text-sm font-medium"><%= p.title %></span>
                        <form action="/admin/delete-project/<%= p.id %>" method="POST"><button class="text-red-500"><i class="fas fa-trash"></i></button></form>
                    </div>
                    <% }) %>
                </div>
            </section>

            <section class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border-t-4 border-orange-500">
                <h2 class="font-black text-orange-600 mb-4 uppercase">Security Settings</h2>
                <form action="/admin/update-profile" method="POST" class="space-y-3">
                    <input type="text" name="new_username" placeholder="New Username" required class="w-full p-2 border rounded dark:bg-gray-800">
                    <input type="password" name="new_password" placeholder="New Password" required class="w-full p-2 border rounded dark:bg-gray-800">
                    <input type="text" name="new_secret" placeholder="Secret Recovery Code" required class="w-full p-2 border rounded dark:bg-gray-800">
                    <button type="submit" class="w-full bg-orange-600 text-white py-3 rounded-xl font-bold">Update Account</button>
                </form>
            </section>
        </div>
    </div>

    <script>
        async function fetchStats() {
            try {
                const res = await fetch('/api/stats');
                const data = await res.json();
                document.getElementById('cpu-val').innerText = data.cpu + "%";
                document.getElementById('ram-val').innerText = data.ramUsed + "GB";
                document.getElementById('load-val').innerText = data.sysLoad;
                document.getElementById('visitor-val').innerText = data.visitors;
            } catch (e) {}
        }
        setInterval(fetchStats, 4000); fetchStats();

        const themeBtn = document.getElementById('theme-toggle'), themeIcon = document.getElementById('theme-icon'), html = document.documentElement;
        if(localStorage.theme === 'dark') { html.classList.add('dark'); themeIcon.innerText = '☀️'; }
        themeBtn.onclick = () => {
            html.classList.toggle('dark'); const isD = html.classList.contains('dark');
            localStorage.theme = isD ? 'dark' : 'light'; themeIcon.innerText = isD ? '☀️' : '🌙';
        }
    </script>
</body>
</html>
