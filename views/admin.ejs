<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-100 font-sans">

    <nav class="bg-white shadow-md p-4 sticky top-0 z-50">
        <div class="container mx-auto flex justify-between items-center">
            <h1 class="text-2xl font-bold text-blue-600">Portfolio Admin</h1>
            <div class="flex items-center gap-4">
                <a href="/" target="_blank" class="text-blue-500 hover:underline">View Site</a>
                <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mx-auto p-6">
        
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
            <div class="bg-white p-6 rounded-xl shadow text-center">
                <p class="text-gray-500">CPU Usage</p>
                <h3 id="cpu-val" class="text-2xl font-bold text-blue-600">--</h3>
            </div>
            <div class="bg-white p-6 rounded-xl shadow text-center">
                <p class="text-gray-500">RAM Status</p>
                <h3 id="ram-val" class="text-2xl font-bold text-green-600">--</h3>
            </div>
            <div class="bg-white p-6 rounded-xl shadow text-center">
                <p class="text-gray-500">System Load</p>
                <h3 id="load-val" class="text-2xl font-bold text-orange-600">--</h3>
            </div>
            <div class="bg-white p-6 rounded-xl shadow text-center">
                <p class="text-gray-500">Total Visitors</p>
                <h3 id="visitor-val" class="text-2xl font-bold text-purple-600">0</h3>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl shadow mb-8">
            <h2 class="text-lg font-bold mb-4 border-b pb-2">Update About Me</h2>
            <form action="/admin/update-about" method="POST" class="flex flex-col gap-3">
                <textarea name="content" rows="3" class="w-full p-3 border rounded-lg" required><%= aboutMe %></textarea>
                <button type="submit" class="bg-blue-600 text-white py-2 px-6 rounded-lg w-fit">Save Bio</button>
            </form>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            
            <section class="bg-white p-6 rounded-xl shadow">
                <h2 class="text-lg font-bold mb-4 text-blue-600 border-b pb-2">Projects</h2>
                <form action="/admin/add-project" method="POST" class="flex flex-col gap-2 mb-6 bg-gray-50 p-4 rounded">
                    <input type="text" name="title" placeholder="Title" required class="p-2 border rounded">
                    <textarea name="description" placeholder="Description" class="p-2 border rounded"></textarea>
                    <input type="url" name="link" placeholder="Link" class="p-2 border rounded">
                    <button type="submit" class="bg-blue-500 text-white py-2 rounded">Add Project</button>
                </form>
                <div class="space-y-2">
                    <% projects.forEach(p => { %>
                        <div class="flex justify-between items-center p-3 border rounded">
                            <span><%= p.title %></span>
                            <form action="/admin/delete-project/<%= p.id %>" method="POST">
                                <button type="submit" class="text-red-500"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                    <% }) %>
                </div>
            </section>

            <section class="bg-white p-6 rounded-xl shadow">
                <h2 class="text-lg font-bold mb-4 text-purple-600 border-b pb-2">Education</h2>
                <form action="/admin/add-education" method="POST" class="flex flex-col gap-2 mb-6 bg-gray-50 p-4 rounded">
                    <input type="text" name="degree" placeholder="Degree" required class="p-2 border rounded">
                    <input type="text" name="institution" placeholder="Institution" required class="p-2 border rounded">
                    <input type="text" name="year" placeholder="Year" required class="p-2 border rounded">
                    <button type="submit" class="bg-purple-500 text-white py-2 rounded">Add Education</button>
                </form>
                <div class="space-y-2">
                    <% education.forEach(e => { %>
                        <div class="flex justify-between items-center p-3 border rounded">
                            <span><%= e.degree %></span>
                            <form action="/admin/delete-education/<%= e.id %>" method="POST">
                                <button type="submit" class="text-red-500"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                    <% }) %>
                </div>
            </section>

            <section class="bg-white p-6 rounded-xl shadow">
                <h2 class="text-lg font-bold mb-4 text-green-600 border-b pb-2">Achievements</h2>
                <form action="/admin/add-achievement" method="POST" class="flex flex-col gap-2 mb-6 bg-gray-50 p-4 rounded">
                    <input type="text" name="title" placeholder="Achievement" required class="p-2 border rounded">
                    <input type="text" name="year" placeholder="Year" required class="p-2 border rounded">
                    <button type="submit" class="bg-green-500 text-white py-2 rounded">Add Achievement</button>
                </form>
                <div class="space-y-2">
                    <% achievements.forEach(a => { %>
                        <div class="flex justify-between items-center p-3 border rounded">
                            <span><%= a.title %></span>
                            <form action="/admin/delete-achievement/<%= a.id %>" method="POST">
                                <button type="submit" class="text-red-500"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                    <% }) %>
                </div>
            </section>

            <section class="bg-white p-6 rounded-xl shadow border-t-4 border-orange-500">
                <h2 class="text-lg font-bold mb-4 text-orange-600">Update Profile</h2>
                <form action="/admin/update-profile" method="POST" class="flex flex-col gap-3">
                    <input type="text" name="new_username" placeholder="New Username" required class="p-2 border rounded">
                    <input type="password" name="new_password" placeholder="New Password" required class="p-2 border rounded">
                    <button type="submit" class="bg-orange-500 text-white py-2 rounded font-bold">Update Credentials</button>
                </form>
            </section>

        </div>
    </div>

    <script>
        async function updateStats() {
            try {
                const res = await fetch('/api/stats');
                const data = await res.json();
                document.getElementById('cpu-val').innerText = data.cpu + " %";
                document.getElementById('ram-val').innerText = data.ramUsed + " / " + data.ramTotal + " GB";
                document.getElementById('load-val').innerText = data.sysLoad;
                document.getElementById('visitor-val').innerText = data.visitors;
            } catch (err) { console.error("Stats error"); }
        }
        setInterval(updateStats, 3000);
        updateStats();
    </script>
</body>
</html>
