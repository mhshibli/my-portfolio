<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        tailwind.config = { darkMode: 'class' }
    </script>
</head>
<body class="bg-gray-100 text-gray-900 dark:bg-gray-900 dark:text-white transition-colors duration-300 font-sans">

    <nav class="p-4 shadow-md bg-white dark:bg-gray-800 flex justify-between items-center transition-colors duration-300">
        <h1 class="text-2xl font-bold text-blue-600 dark:text-blue-400">Admin Dashboard</h1>
        <div class="flex gap-4">
            <a href="/" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition">View Site</a>
            <button id="theme-toggle" class="px-4 py-2 bg-gray-200 dark:bg-gray-700 rounded-lg font-semibold transition hover:bg-gray-300 dark:hover:bg-gray-600">
                🌙 Dark Mode
            </button>
        </div>
    </nav>

    <div class="container mx-auto p-6 mt-4">
        
        <h2 class="text-xl font-bold mb-4 border-b pb-2 border-gray-300 dark:border-gray-700">Server Statistics (Live)</h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-10">
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-md border-l-4 border-blue-500"><h3 class="text-sm text-gray-500 dark:text-gray-400">CPU Usage</h3><p class="text-3xl font-bold mt-2"><span id="cpu-stat">0</span>%</p></div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-md border-l-4 border-green-500"><h3 class="text-sm text-gray-500 dark:text-gray-400">RAM Usage</h3><p class="text-3xl font-bold mt-2"><span id="ram-stat">0</span> GB</p></div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-md border-l-4 border-yellow-500"><h3 class="text-sm text-gray-500 dark:text-gray-400">System Load</h3><p class="text-3xl font-bold mt-2"><span id="load-stat">0</span></p></div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-md border-l-4 border-purple-500"><h3 class="text-sm text-gray-500 dark:text-gray-400">Total Visitors</h3><p class="text-3xl font-bold mt-2" id="visitor-stat">0</p></div>
        </div>

        <h2 class="text-xl font-bold mb-4 border-b pb-2 border-gray-300 dark:border-gray-700">Upload Content</h2>
        
        <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-md mb-6 border-l-4 border-indigo-500">
            <h3 class="font-bold mb-4 text-indigo-600 dark:text-indigo-400">Update 'About Me'</h3>
            <form action="/admin/update-about" method="POST" class="flex flex-col gap-3">
                <textarea name="content" required rows="3" placeholder="Write something about yourself..." class="p-3 border rounded-lg dark:bg-gray-700 dark:border-gray-600 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-gray-900 dark:text-white"><%= aboutMe %></textarea>
                <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 rounded transition w-full md:w-auto md:self-start px-6">Save About Me</button>
            </form>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-md">
                <h3 class="font-bold mb-4 text-blue-600 dark:text-blue-400">Add Project</h3>
                <form action="/admin/add-project" method="POST" class="flex flex-col gap-3">
                    <input type="text" name="title" placeholder="Title" required class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600 text-gray-900 dark:text-white">
                    <textarea name="description" placeholder="Description" required rows="2" class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600 text-gray-900 dark:text-white"></textarea>
                    <input type="url" name="link" placeholder="Link (Optional)" class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600 text-gray-900 dark:text-white">
                    <button type="submit" class="bg-blue-600 text-white font-bold py-2 rounded hover:bg-blue-700">Save</button>
                </form>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-md">
                <h3 class="font-bold mb-4 text-purple-600 dark:text-purple-400">Add Education</h3>
                <form action="/admin/add-education" method="POST" class="flex flex-col gap-3">
                    <input type="text" name="degree" placeholder="Degree" required class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600 text-gray-900 dark:text-white">
                    <input type="text" name="institution" placeholder="Institution" required class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600 text-gray-900 dark:text-white">
                    <input type="text" name="year" placeholder="Year" required class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600 text-gray-900 dark:text-white">
                    <textarea name="description" placeholder="Details (Optional)" rows="1" class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600 text-gray-900 dark:text-white"></textarea>
                    <button type="submit" class="bg-purple-600 text-white font-bold py-2 rounded hover:bg-purple-700">Save</button>
                </form>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-md">
                <h3 class="font-bold mb-4 text-green-600 dark:text-green-400">Add Achievement</h3>
                <form action="/admin/add-achievement" method="POST" class="flex flex-col gap-3">
                    <input type="text" name="title" placeholder="Title" required class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600 text-gray-900 dark:text-white">
                    <input type="text" name="year" placeholder="Year" required class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600 text-gray-900 dark:text-white">
                    <textarea name="description" placeholder="Description (Optional)" rows="1" class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600 text-gray-900 dark:text-white"></textarea>
                    <button type="submit" class="bg-green-600 text-white font-bold py-2 rounded hover:bg-green-700">Save</button>
                </form>
            </div>
        </div>

        <h2 class="text-xl font-bold mb-4 border-b pb-2 border-gray-300 dark:border-gray-700">Manage Uploaded Content</h2>
        
        <h3 class="text-lg font-bold mb-3 text-blue-600 dark:text-blue-400">Projects</h3>
        <div class="bg-white dark:bg-gray-800 shadow-md rounded-lg overflow-hidden mb-8">
            <table class="w-full text-left">
                <tr class="bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300"><th class="p-4">Title</th><th class="p-4 w-32 text-center">Actions</th></tr>
                <% projects.forEach(item => { %>
                <tr class="border-b border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition">
                    <td class="p-4 font-semibold"><%= item.title %></td>
                    <td class="p-4 flex gap-3 justify-center">
                        <a href="/admin/edit/project/<%= item.id %>" class="text-blue-500 hover:text-blue-700"><i class="fas fa-edit"></i></a>
                        <form action="/admin/delete-project/<%= item.id %>" method="POST" onsubmit="return confirm('Delete this?');">
                            <button type="submit" class="text-red-500 hover:text-red-700"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            </table>
        </div>

        <h3 class="text-lg font-bold mb-3 text-purple-600 dark:text-purple-400">Education</h3>
        <div class="bg-white dark:bg-gray-800 shadow-md rounded-lg overflow-hidden mb-8">
            <table class="w-full text-left">
                <tr class="bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300"><th class="p-4">Degree</th><th class="p-4 w-32 text-center">Actions</th></tr>
                <% education.forEach(item => { %>
                <tr class="border-b border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition">
                    <td class="p-4 font-semibold"><%= item.degree %></td>
                    <td class="p-4 flex gap-3 justify-center">
                        <a href="/admin/edit/education/<%= item.id %>" class="text-blue-500 hover:text-blue-700"><i class="fas fa-edit"></i></a>
                        <form action="/admin/delete-education/<%= item.id %>" method="POST" onsubmit="return confirm('Delete this?');">
                            <button type="submit" class="text-red-500 hover:text-red-700"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            </table>
        </div>

        <h3 class="text-lg font-bold mb-3 text-green-600 dark:text-green-400">Achievements</h3>
        <div class="bg-white dark:bg-gray-800 shadow-md rounded-lg overflow-hidden mb-8">
            <table class="w-full text-left">
                <tr class="bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300"><th class="p-4">Title</th><th class="p-4 w-32 text-center">Actions</th></tr>
                <% achievements.forEach(item => { %>
                <tr class="border-b border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition">
                    <td class="p-4 font-semibold"><%= item.title %></td>
                    <td class="p-4 flex gap-3 justify-center">
                        <a href="/admin/edit/achievement/<%= item.id %>" class="text-blue-500 hover:text-blue-700"><i class="fas fa-edit"></i></a>
                        <form action="/admin/delete-achievement/<%= item.id %>" method="POST" onsubmit="return confirm('Delete this?');">
                            <button type="submit" class="text-red-500 hover:text-red-700"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            </table>
        </div>

    </div>

    <script>
        const toggleBtn = document.getElementById('theme-toggle');
        const htmlTag = document.documentElement;
        toggleBtn.addEventListener('click', () => {
            htmlTag.classList.toggle('dark');
            toggleBtn.innerText = htmlTag.classList.contains('dark') ? '☀️ Light Mode' : '🌙 Dark Mode';
        });

        async function fetchStats() {
            try {
                const res = await fetch('/api/stats');
                const data = await res.json();
                document.getElementById('cpu-stat').innerText = data.cpu;
                document.getElementById('ram-stat').innerText = data.ramUsed;
                document.getElementById('load-stat').innerText = data.sysLoad;
                document.getElementById('visitor-stat').innerText = data.visitors;
            } catch (error) {}
        }
        fetchStats(); setInterval(fetchStats, 2000);
    </script>
</body>
</html>