<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        tailwind.config = { darkMode: 'class' }
    </script>
</head>
<body class="bg-gray-100 text-gray-900 dark:bg-gray-900 dark:text-white transition-colors duration-300 font-sans">

    <nav class="p-4 shadow-md bg-white dark:bg-gray-800 flex justify-between items-center transition-colors duration-300 sticky top-0 z-50">
        <h1 class="text-2xl font-bold text-blue-600 dark:text-blue-400">Admin Dashboard</h1>
        <div class="flex gap-4 items-center">
            <span class="text-sm font-medium hidden md:block">User: <%= currentAdmin %></span>
            <a href="/" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition">View Site</a>
            <a href="/logout" class="px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600 transition">Logout</a>
            <button id="theme-toggle" class="px-3 py-2 bg-gray-200 dark:bg-gray-700 rounded-lg">🌙</button>
        </div>
    </nav>

    <div class="container mx-auto p-6 mt-4">
        
        <h2 class="text-xl font-bold mb-4 border-b pb-2 dark:border-gray-700">Update Personal Bio</h2>
        <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-md mb-8">
            <form action="/admin/update-about" method="POST" class="flex flex-col gap-3">
                <textarea name="content" required rows="3" class="p-3 border rounded-lg dark:bg-gray-700 dark:border-gray-600 text-gray-900 dark:text-white"><%= aboutMe %></textarea>
                <button type="submit" class="bg-indigo-600 text-white font-bold py-2 rounded px-6 self-start hover:bg-indigo-700 transition">Save About Me</button>
            </form>
        </div>

        <h2 class="text-xl font-bold mb-4 border-b pb-2 dark:border-gray-700">Add New Content</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-md">
                <h3 class="font-bold mb-4 text-blue-500">Add Project</h3>
                <form action="/admin/add-project" method="POST" class="flex flex-col gap-3">
                    <input type="text" name="title" placeholder="Title" required class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600">
                    <textarea name="description" placeholder="Description" required rows="2" class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600"></textarea>
                    <input type="url" name="link" placeholder="Link (Optional)" class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600">
                    <button type="submit" class="bg-blue-600 text-white font-bold py-2 rounded">Save</button>
                </form>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-md">
                <h3 class="font-bold mb-4 text-purple-500">Add Education</h3>
                <form action="/admin/add-education" method="POST" class="flex flex-col gap-3">
                    <input type="text" name="degree" placeholder="Degree" required class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600">
                    <input type="text" name="institution" placeholder="Institution" required class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600">
                    <input type="text" name="year" placeholder="Year" required class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600">
                    <button type="submit" class="bg-purple-600 text-white font-bold py-2 rounded">Save</button>
                </form>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-md">
                <h3 class="font-bold mb-4 text-green-500">Add Achievement</h3>
                <form action="/admin/add-achievement" method="POST" class="flex flex-col gap-3">
                    <input type="text" name="title" placeholder="Title" required class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600">
                    <input type="text" name="year" placeholder="Year" required class="p-2 border rounded dark:bg-gray-700 dark:border-gray-600">
                    <button type="submit" class="bg-green-600 text-white font-bold py-2 rounded">Save</button>
                </form>
            </div>
        </div>

        <h2 class="text-xl font-bold mb-4 border-b pb-2 dark:border-gray-700">Account Settings</h2>
        <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-md mb-12 border-t-4 border-orange-500 transition-colors">
            <h3 class="font-bold mb-4 text-orange-500">Update Credentials</h3>
            <form action="/admin/update-profile" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <input type="text" name="new_username" placeholder="New Username" required class="p-3 border rounded-lg dark:bg-gray-700 dark:border-gray-600">
                <input type="password" name="new_password" placeholder="New Password" required class="p-3 border rounded-lg dark:bg-gray-700 dark:border-gray-600">
                <button type="submit" class="bg-orange-500 text-white font-bold py-3 rounded-lg md:col-span-2 hover:bg-orange-600 transition">Update Profile</button>
            </form>
        </div>

        <h2 class="text-xl font-bold mb-4 border-b pb-2 dark:border-gray-700">Manage Content</h2>
        <div class="grid grid-cols-1 gap-4 mb-20">
            <% projects.forEach(item => { %>
                <div class="bg-white dark:bg-gray-800 p-4 rounded-lg flex justify-between items-center shadow-sm">
                    <span><%= item.title %> (Project)</span>
                    <form action="/admin/delete-project/<%= item.id %>" method="POST">
                        <button type="submit" class="text-red-500 hover:text-red-700"><i class="fas fa-trash"></i></button>
                    </form>
                </div>
            <% }) %>
        </div>

    </div>

    <script>
        const toggleBtn = document.getElementById('theme-toggle');
        const htmlTag = document.documentElement;
        toggleBtn.addEventListener('click', () => {
            htmlTag.classList.toggle('dark');
            toggleBtn.innerText = htmlTag.classList.contains('dark') ? '☀️' : '🌙';
        });
    </script>
</body>
</html>