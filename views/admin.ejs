<section class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow">
    <h2 class="font-black text-orange-500 mb-4 uppercase">Photo Gallery</h2>
    
    <form action="/admin/upload-photo" method="POST" enctype="multipart/form-data" class="bg-gray-50 dark:bg-gray-700 p-4 rounded-xl space-y-3 mb-6">
        <label class="block text-xs font-bold text-gray-500">Select Image</label>
        <input type="file" name="imageFile" accept="image/*" required class="w-full p-2 border rounded dark:bg-gray-800">
        
        <input type="text" name="caption" placeholder="Caption (e.g. My Graduation)" class="w-full p-2 border rounded dark:bg-gray-800">
        
        <button type="submit" class="w-full bg-orange-500 text-white py-2 rounded-lg font-bold">
            <i class="fas fa-upload mr-2"></i> Upload to Storage
        </button>
    </form>

    <div class="grid grid-cols-3 gap-3 max-h-60 overflow-y-auto">
        <% gallery.forEach(img => { %>
        <div class="relative group">
            <img src="<%= img.image_url %>" class="w-full h-24 object-cover rounded-lg border dark:border-gray-600">
            <form action="/admin/delete-photo/<%= img.id %>" method="POST" class="absolute top-1 right-1">
                <button class="bg-red-500 text-white p-1 rounded-full text-[10px]"><i class="fas fa-trash"></i></button>
            </form>
        </div>
        <% }) %>
    </div>
</section>
