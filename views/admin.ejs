<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | Mahmudul Hasan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>tailwind.config = { darkMode: 'class' }</script>
    <style>
        html { scroll-behavior: smooth; }
        
        /* --- Deep Ash Theme (Eye-Care Light Mode for Admin) --- */
        .light body { 
            background-color: #cbd5e1; 
            color: #0f172a; 
        }
        
        /* Floating Card Style for Admin Panel */
        .light .admin-card, .light .message-item { 
            background-color: #f1f5f9; 
            border: 1px solid #94a3b8; 
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1); 
            transition: all 0.3s ease;
        }
        .light .admin-card:hover { 
            transform: translateY(-4px); 
            box-shadow: 0 20px 35px -5px rgba(0, 0, 0, 0.15); 
        }
        
        /* Message Inbox Hover & Open Style */
        .light .message-item:hover { background-color: #e2e8f0; }
        .message-body { max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out; }
        .message-item.open .message-body { max-height: 500px; padding-top: 1rem; border-top: 1px solid #94a3b8; margin-top: 1rem; }
        .dark .message-item.open .message-body { border-top-color: #374151; }
    </style>
</head>
<body class="dark:bg-gray-900 dark:text-gray-100 min-h-screen transition-colors duration-300">
    
    <nav class="bg-gray-800 text-white shadow p-4 sticky top-0 z-50 flex justify-between items-center border-b border-gray-700">
        <h1 class="text-xl font-bold text-blue-400 italic uppercase tracking-tighter">Mahmudul Admin</h1>
        <div class="flex items-center gap-4">
            <button id="theme-toggle" class="p-2 rounded-lg bg-gray-700 text-yellow-400 shadow-inner transition hover:scale-110">🌙</button>
            <a href="/logout" class="bg-red-500 hover:bg-red-600 text-white px-5 py-2 rounded-lg font-bold text-sm shadow-md transition">Logout</a>
        </div>
    </nav>

    <div class="container mx-auto p-4 md:p-6 space-y-12">
        
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="admin-card dark:bg-gray-800 p-6 rounded-3xl flex items-center justify-between">
                <div>
                    <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">CPU Usage</p>
                    <h3 class="text-3xl font-black text-blue-600 dark:text-blue-400" id="cpu-stat">12%</h3>
                </div>
                <div class="w-14 h-14 rounded-full bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center">
                    <i class="fas fa-microchip text-blue-600 dark:text-blue-400 text-2xl"></i>
                </div>
            </div>

            <div class="admin-card dark:bg-gray-800 p-6 rounded-3xl flex items-center justify-between">
                <div>
                    <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">RAM Usage</p>
                    <h3 class="text-3xl font-black text-purple-600 dark:text-purple-400" id="ram-stat">2.4 <span class="text-sm">GB</span></h3>
                </div>
                <div class="w-14 h-14 rounded-full bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center">
                    <i class="fas fa-memory text-purple-600 dark:text-purple-400 text-2xl"></i>
                </div>
            </div>

            <div class="admin-card dark:bg-gray-800 p-6 rounded-3xl flex items-center justify-between">
                <div>
                    <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Total Visitors</p>
                    <h3 class="text-3xl font-black text-green-600 dark:text-green-400">1,245</h3>
                </div>
                <div class="w-14 h-14 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
                    <i class="fas fa-users text-green-600 dark:text-green-400 text-2xl"></i>
                </div>
            </div>

            <div class="admin-card dark:bg-gray-800 p-6 rounded-3xl flex items-center justify-between">
                <div>
                    <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Server Ping</p>
                    <h3 class="text-3xl font-black text-orange-600 dark:text-orange-400" id="ping-stat">45 <span class="text-sm">ms</span></h3>
                </div>
                <div class="w-14 h-14 rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center">
                    <i class="fas fa-server text-orange-600 dark:text-orange-400 text-2xl"></i>
                </div>
            </div>
        </section>

        <section class="admin-card dark:bg-gray-800 p-6 rounded-3xl">
            <h2 class="font-black mb-4 text-blue-600 uppercase tracking-widest border-b pb-2">Edit About Me</h2>
            <form action="/admin/update-about" method="POST" class="space-y-4">
                <textarea name="content" rows="4" class="w-full p-4 border rounded-xl dark:bg-gray-900 dark:border-gray-700 text-gray-900 dark:text-white" required><%= aboutMe %></textarea>
                <button type="submit" class="bg-blue-600 text-white px-8 py-3 rounded-xl font-bold shadow-md hover:bg-blue-700 transition">Update Bio</button>
            </form>
        </section>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <section class="admin-card dark:bg-gray-800 p-6 rounded-3xl">
                <h2 class="font-bold mb-4 text-purple-600 uppercase tracking-widest border-b pb-2">Manage Education</h2>
                <form action="/admin/add-education" method="POST" class="flex flex-col gap-2 mb-6">
                    <input type="text" name="degree" placeholder="Degree" required class="p-2 border rounded dark:bg-gray-900 text-sm">
                    <input type="text" name="institution" placeholder="Institution" required class="p-2 border rounded dark:bg-gray-900 text-sm">
                    <input type="text" name="year" placeholder="Year" required class="p-2 border rounded dark:bg-gray-900 text-sm">
                    <button type="submit" class="bg-purple-600 text-white py-2 rounded-xl font-bold uppercase text-xs">Add Education</button>
                </form>
                <div class="space-y-2 max-h-48 overflow-y-auto pr-2">
                    <% education.forEach(e => { %>
                    <div class="flex justify-between items-center p-3 border dark:border-gray-700 rounded-lg bg-white dark:bg-gray-900/30">
                        <span class="text-xs font-bold"><%= e.degree %></span>
                        <form action="/admin/delete-education/<%= e.id %>" method="POST"><button class="text-red-400 hover:text-red-600"><i class="fas fa-trash"></i></button></form>
                    </div>
                    <% }) %>
                </div>
            </section>

            <section class="admin-card dark:bg-gray-800 p-6 rounded-3xl">
                <h2 class="font-bold mb-4 text-blue-600 uppercase tracking-widest border-b pb-2">Manage Projects</h2>
                <form action="/admin/add-project" method="POST" class="flex flex-col gap-2 mb-6">
                    <input type="text" name="title" placeholder="Project Title" required class="p-2 border rounded dark:bg-gray-900 text-sm">
                    <textarea name="description" placeholder="Project Description" class="p-2 border rounded dark:bg-gray-900 text-xs"></textarea>
                    <button type="submit" class="bg-blue-500 text-white py-2 rounded-xl font-bold uppercase text-xs">Add Project</button>
                </form>
                <div class="space-y-2 max-h-48 overflow-y-auto pr-2">
                    <% projects.forEach(p => { %>
                    <div class="flex justify-between items-center p-3 border dark:border-gray-700 rounded-lg bg-white dark:bg-gray-900/30">
                        <span class="text-xs font-bold text-blue-600 dark:text-blue-400"><%= p.title %></span>
                        <form action="/admin/delete-project/<%= p.id %>" method="POST"><button class="text-red-400 hover:text-red-600"><i class="fas fa-trash"></i></button></form>
                    </div>
                    <% }) %>
                </div>
            </section>
        </div>

        <section class="admin-card dark:bg-gray-800 p-6 rounded-3xl">
            <h2 class="font-black text-orange-500 mb-6 uppercase tracking-widest border-b pb-2">Photo Gallery Management</h2>
            <form action="/admin/upload-photo" method="POST" enctype="multipart/form-data" class="bg-white dark:bg-gray-700 p-6 rounded-2xl space-y-4 mb-10 border border-dashed border-gray-300 dark:border-gray-600">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <input type="file" name="imageFile" required class="p-2 border rounded dark:bg-gray-800">
                    <input type="text" name="caption" placeholder="Photo Caption" required class="p-2 border rounded dark:bg-gray-900">
                </div>
                <textarea name="description" placeholder="Detail Description..." class="w-full p-3 border rounded dark:bg-gray-900 text-sm" rows="2"></textarea>
                <button type="submit" class="w-full bg-orange-500 text-white py-3 rounded-xl font-bold uppercase tracking-widest shadow-md hover:bg-orange-600 transition">+ Upload Photo</button>
            </form>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-h-[600px] overflow-y-auto pr-2">
                <% gallery.forEach(img => { %>
                <div class="flex flex-col gap-3 p-4 border dark:border-gray-700 rounded-2xl bg-white dark:bg-gray-900/50 shadow-sm relative">
                    <img src="<%= img.image_url %>" class="w-full h-32 object-cover rounded-xl border dark:border-gray-700">
                    <form action="/admin/update-photo/<%= img.id %>" method="POST" class="space-y-2">
                        <input type="text" name="caption" value="<%= img.caption %>" class="w-full text-xs font-bold p-2 border rounded dark:bg-gray-800">
                        <textarea name="description" class="w-full text-[10px] p-2 border rounded dark:bg-gray-800" rows="2"><%= img.description %></textarea>
                        <div class="flex justify-between items-center pt-1">
                            <button type="submit" class="bg-blue-600 text-white text-[10px] px-3 py-1.5 rounded-lg font-bold">Update</button>
                            <button type="submit" formaction="/admin/delete-photo/<%= img.id %>" class="bg-red-500 text-white text-[10px] px-3 py-1.5 rounded-lg font-bold">Delete</button>
                        </div>
                    </form>
                </div>
                <% }) %>
            </div>
        </section>

        <section class="admin-card dark:bg-gray-800 p-6 rounded-3xl">
            <h2 class="font-black text-blue-600 mb-6 uppercase tracking-widest border-b pb-2 flex items-center gap-2">
                <i class="fas fa-inbox text-orange-500"></i> Visitor Inbox
            </h2>
            <div class="space-y-3 max-h-[500px] overflow-y-auto pr-2">
                <% if (messages && messages.length > 0) { %>
                    <% messages.forEach((m) => { %>
                    <div class="message-item border dark:border-gray-700 rounded-xl bg-white dark:bg-gray-900/50 p-4 cursor-pointer" onclick="this.classList.toggle('open')">
                        <div class="flex justify-between items-center">
                            <div class="flex items-center gap-4 flex-grow truncate">
                                <i class="fas fa-envelope text-blue-400 text-sm"></i>
                                <span class="font-bold text-sm min-w-[120px] text-blue-600 dark:text-blue-400"><%= m.name %></span>
                                <span class="text-xs text-gray-500 dark:text-gray-400 truncate ml-4 italic">— <%= m.message.substring(0, 50) %>...</span>
                            </div>
                            <div class="flex items-center gap-4">
                                <span class="text-[10px] text-gray-400 whitespace-nowrap"><%= new Date(m.created_at).toLocaleDateString() %></span>
                                <form action="/admin/delete-message/<%= m.id %>" method="POST" onclick="event.stopPropagation()">
                                    <button type="submit" class="text-red-400 hover:text-red-600 p-1"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            </div>
                        </div>
                        <div class="message-body min-h-0 overflow-hidden">
                            <div class="pt-4 mt-4 border-t dark:border-gray-700">
                                <p class="text-[11px] font-bold text-gray-400 uppercase">From: <span class="text-blue-500"><%= m.name %> (<%= m.email %>)</span></p>
                                <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-wrap mt-2"><%= m.message %></p>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-center text-gray-400 py-10 italic">No messages found in your inbox.</p>
                <% } %>
            </div>
        </section>

        <section class="admin-card dark:bg-gray-800 p-6 rounded-3xl border-t-8 border-orange-500">
            <h2 class="font-black text-orange-600 mb-6 uppercase tracking-widest border-b pb-2">Admin Security Settings</h2>
            <form action="/admin/update-profile" method="POST" class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <input type="text" name="new_username" placeholder="New Username" required class="p-3 border rounded-xl dark:bg-gray-900">
                <input type="password" name="new_password" placeholder="New Password" required class="p-3 border rounded-xl dark:bg-gray-900">
                <input type="text" name="new_secret" placeholder="Secret Recovery Code" required class="p-3 border rounded-xl dark:bg-gray-900">
                <button type="submit" class="bg-orange-600 text-white py-4 rounded-xl font-black uppercase tracking-widest shadow-xl md:col-span-3 hover:bg-orange-700 transition">Update Credentials</button>
            </form>
        </section>

    </div>

    <script>
        // Theme Toggle Logic
        const themeBtn = document.getElementById('theme-toggle'), html = document.documentElement;
        if(localStorage.theme === 'dark') html.classList.add('dark');
        themeBtn.onclick = () => { 
            html.classList.toggle('dark'); 
            localStorage.theme = html.classList.contains('dark') ? 'dark' : 'light'; 
        }

        // Live Dashboard Animation (CPU, RAM, Ping)
        setInterval(() => {
            // CPU: 8% থেকে 25% এর মধ্যে রেন্ডম নাম্বার
            document.getElementById('cpu-stat').innerText = Math.floor(Math.random() * (25 - 8 + 1) + 8) + '%';
            
            // RAM: 2.0 GB থেকে 3.5 GB এর মধ্যে রেন্ডম নাম্বার
            document.getElementById('ram-stat').innerHTML = (Math.random() * (3.5 - 2.0) + 2.0).toFixed(1) + ' <span class="text-sm">GB</span>';
            
            // Ping: 30ms থেকে 60ms এর মধ্যে রেন্ডম নাম্বার
            document.getElementById('ping-stat').innerHTML = Math.floor(Math.random() * (60 - 30 + 1) + 30) + ' <span class="text-sm">ms</span>';
        }, 3000); // প্রতি ৩ সেকেন্ড পরপর আপডেট হবে
    </script>
</body>
</html>
