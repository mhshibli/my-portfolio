<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | Portfolio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        tailwind.config = { darkMode: 'class' }
    </script>
    <style>
        body { transition: background-color 0.3s, color 0.3s; }
        .glass-card { 
            background: rgba(255, 255, 255, 0.9); 
            backdrop-filter: blur(10px);
        }
        .dark .glass-card { 
            background: rgba(31, 41, 55, 0.8); 
        }
    </style>
</head>
<body class="bg-gray-100 text-gray-900 dark:bg-gray-900 dark:text-gray-100 min-h-screen">

    <nav class="bg-white/80 dark:bg-gray-800/80 backdrop-blur-md sticky top-0 z-50 border-b dark:border-gray-700 p-4">
        <div class="container mx-auto flex justify-between items-center">
            <div class="flex items-center gap-4">
                <h1 class="text-xl font-bold text-blue-600 dark:text-blue-400">ADMIN PANEL</h1>
                <a href="/" target="_blank" class="hidden sm:block text-xs font-bold bg-blue-100 text-blue-600 px-2 py-1 rounded">VIEW SITE</a>
            </div>
            
            <div class="flex items-center gap-3">
                <button id="theme-toggle" class="p-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition">
                    <span id="theme-icon">🌙</span>
                </button>
                <a href="/logout" class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg text-sm font-bold shadow-md">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mx-auto p-4 md:p-8 space-y-8">
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="glass-card p-6 rounded-2xl shadow-sm border dark:border-gray-700 text-center">
                <p class="text-xs font-bold text-gray-500 uppercase mb-2">CPU Usage</p>
                <h3 id="cpu-val" class="text-2xl font-black text-blue-600">--</h3>
            </div>
            <div class="glass-card p-6 rounded-2xl shadow-sm border dark:border-gray-700 text-center">
                <p class="text-xs font-bold text-gray-500 uppercase mb-2">RAM Usage</p>
                <h3 id="ram-val" class="text-2xl font-black text-green-600">--</h3>
            </div>
            <div class="glass-card p-6 rounded-2xl shadow-sm border dark:border-gray-700 text-center">
                <p class="text-xs font-bold text-gray-500 uppercase mb-2">Sys Load</p>
                <h3 id="load-val" class="text-2xl font-black text-orange-600">--</h3>
            </div>
            <div class="glass-card p-6 rounded-2xl shadow-sm border-2 border-purple-500/30 text-center">
                <p class="text-xs font-bold text-gray-500 uppercase mb-2">Total Visitors</p>
                <h3 id="visitor-val" class="text-2xl font-black text-purple-600">0</h3>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            
            <div class="space-y-8">
                <section class="glass-card p-6 rounded-2xl border dark:border-gray-700 shadow-sm">
                    <h2 class="text-lg font-bold mb-4 flex items-center gap-2"><i class="fas fa-user-edit text-blue-500"></i> Edit About Me</h2>
                    <form action="/admin/update-about" method="POST" class="space-y-4">
                        <textarea name="content" rows="4" class="w-full p-4 rounded-xl border dark:bg-gray-800 dark:border-gray-600 focus:ring-2 focus:ring-blue-500 outline-none" required><%= aboutMe %></textarea>
                        <button type="submit" class="w-full bg-blue-600 text-white font-bold py-3 rounded-xl hover:bg-blue-700 transition">Update Bio</button>
                    </form>
                </section>

                <section class="glass-card p-6 rounded-2xl border dark:border-gray-700 shadow-sm">
                    <h2 class="text-lg font-bold mb-4 text-blue-600">Manage Projects</h2>
                    <form action="/admin/add-project" method="POST" class="bg-gray-50 dark:bg-gray-800/50 p-4 rounded-xl space-y-3 mb-6">
                        <input type="text" name="title" placeholder="Project Title" required class="w-full p-2 rounded border dark:bg-gray-800 dark:border-gray-600">
                        <textarea name="description" placeholder="Short Description" class="w-full p-2 rounded border dark:bg-gray-800 dark:border-gray-600"></textarea>
                        <input type="url" name="link" placeholder="Project Link (Optional)" class="w-full p-2 rounded border dark:bg-gray-800 dark:border-gray-600">
                        <button type="submit" class="w-full bg-blue-500 text-white py-2 rounded-lg font-bold">+ Add Project</button>
                    </form>
                    <div class="space-y-2 max-h-64 overflow-y-auto pr-2">
                        <% projects.forEach(p => { %>
                        <div class="flex justify-between items-center p-3 bg-white dark:bg-gray-800 border dark:border-gray-700 rounded-lg shadow-sm">
                            <span class="font-medium text-sm truncate"><%= p.title %></span>
                            <form action="/admin/delete-project/<%= p.id %>" method="POST">
                                <button type="submit" class="text-red-500 hover:bg-red-50 p-2 rounded-lg"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                        <% }) %>
                    </div>
                </section>
            </div>

            <div class="space-y-8">
                <section class="glass-card p-6 rounded-2xl border dark:border-gray-700 shadow-sm">
                    <h2 class="text-lg font-bold mb-4 text-purple-600">Education</h2>
                    <form action="/admin/add-education" method="POST" class="space-y-2 mb-6">
                        <input type="text" name="degree" placeholder="Degree" required class="w-full p-2 rounded border dark:bg-gray-800 dark:border-gray-600">
                        <input type="text" name="institution" placeholder="Institution" required class="w-full p-2 rounded border dark:bg-gray-800 dark:border-gray-600">
                        <input type="text" name="year" placeholder="Year" required class="w-full p-2 rounded border dark:bg-gray-800 dark:border-gray-600">
                        <button type="submit" class="w-full bg-purple-600 text-white py-2 rounded-lg font-bold">+ Add</button>
                    </form>
                    <% education.forEach(e => { %>
                    <div class="flex justify-between items-center p-2 border-b dark:border-gray-700 text-xs">
                        <span><%= e.degree %></span>
                        <form action="/admin/delete-education/<%= e.id %>" method="POST"><button class="text-red-400"><i class="fas fa-times"></i></button></form>
                    </div>
                    <% }) %>
                </section>

                <section class="glass-card p-6 rounded-2xl border dark:border-gray-700 shadow-sm">
                    <h2 class="text-lg font-bold mb-4 text-green-600">Achievements</h2>
                    <form action="/admin/add-achievement" method="POST" class="space-y-2 mb-6">
                        <input type="text" name="title" placeholder="Title" required class="w-full p-2 rounded border dark:bg-gray-800 dark:border-gray-600">
                        <input type="text" name="year" placeholder="Year" required class="w-full p-2 rounded border dark:bg-gray-800 dark:border-gray-600">
                        <button type="submit" class="w-full bg-green-600 text-white py-2 rounded-lg font-bold">+ Add</button>
                    </form>
                    <% achievements.forEach(a => { %>
                    <div class="flex justify-between items-center p-2 border-b dark:border-gray-700 text-xs">
                        <span><%= a.title %></span>
                        <form action="/admin/delete-achievement/<%= a.id %>" method="POST"><button class="text-red-400"><i class="fas fa-times"></i></button></form>
                    </div>
                    <% }) %>
                </section>

                <section class="glass-card p-6 rounded-2xl border-t-4 border-orange-500 shadow-lg">
                    <h2 class="text-lg font-bold mb-4 text-orange-600">Admin Security</h2>
                    <form action="/admin/update-profile" method="POST" class="space-y-3">
                        <input type="text" name="new_username" placeholder="New Username" required class="w-full p-2 border rounded dark:bg-gray-800">
                        <input type="password" name="new_password" placeholder="New Password" required class="w-full p-2 border rounded dark:bg-gray-800">
                        <input type="text" name="new_secret" placeholder="Secret Recovery Code" required class="w-full p-2 border rounded dark:bg-gray-800 bg-orange-50/50">
                        <button type="submit" class="w-full bg-orange-500 text-white py-2 rounded-xl font-bold shadow-md">Update Credentials</button>
                    </form>
                </section>
            </div>
        </div>
    </div>

    <script>
        // 1. Dark Mode Toggle
        const themeToggle = document.getElementById('theme-toggle');
        const themeIcon = document.getElementById('theme-icon');
        const html = document.documentElement;

        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            html.classList.add('dark');
            themeIcon.innerText = '☀️';
        }

        themeToggle.addEventListener('click', () => {
            html.classList.toggle('dark');
            const isDark = html.classList.contains('dark');
            themeIcon.innerText = isDark ? '☀️' : '🌙';
            localStorage.theme = isDark ? 'dark' : 'light';
        });

        // 2. Fetch Stats & Visitors
        async function fetchStats() {
            try {
                const res = await fetch('/api/stats');
                const data = await res.json();
                
                document.getElementById('cpu-val').innerText = data.cpu + "%";
                document.getElementById('ram-val').innerText = data.ramUsed + "GB";
                document.getElementById('load-val').innerText = data.sysLoad;
                document.getElementById('visitor-val').innerText = data.visitors;
            } catch (err) {
                console.error("Error fetching stats:", err);
            }
        }

        // প্রতি ৪ সেকেন্ড পর পর ডাটা আপডেট হবে
        setInterval(fetchStats, 4000);
        fetchStats(); // প্রাথমিক লোড
    </script>
</body>
</html>
