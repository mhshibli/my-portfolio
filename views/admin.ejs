<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-100 font-sans min-h-screen">

    <nav class="bg-white shadow-md p-4 sticky top-0 z-50">
        <div class="container mx-auto flex flex-wrap justify-between items-center gap-4">
            <h1 class="text-xl font-bold text-blue-600">Admin <span class="hidden sm:inline">Dashboard</span></h1>
            
            <div class="flex items-center gap-2">
                <a href="/" target="_blank" class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg text-sm font-bold">Site</a>
                <a href="/logout" class="bg-red-500 text-white px-3 py-2 rounded-lg text-sm hover:bg-red-600">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mx-auto p-4 md:p-6">
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8">
            <div class="bg-white p-4 rounded-xl shadow-sm text-center">
                <p class="text-xs text-gray-500 mb-1 font-bold">CPU</p>
                <h3 id="cpu-val" class="text-sm md:text-lg font-bold text-blue-600">--</h3>
            </div>
            <div class="bg-white p-4 rounded-xl shadow-sm text-center">
                <p class="text-xs text-gray-500 mb-1 font-bold">RAM</p>
                <h3 id="ram-val" class="text-sm md:text-lg font-bold text-green-600">--</h3>
            </div>
            <div class="bg-white p-4 rounded-xl shadow-sm text-center">
                <p class="text-xs text-gray-500 mb-1 font-bold">LOAD</p>
                <h3 id="load-val" class="text-sm md:text-lg font-bold text-orange-600">--</h3>
            </div>
            <div class="bg-white p-4 rounded-xl shadow-sm text-center border-2 border-purple-100">
                <p class="text-xs text-gray-500 mb-1 font-bold">VISITORS</p>
                <h3 id="visitor-val" class="text-sm md:text-lg font-bold text-purple-600">0</h3>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            
            <section class="bg-white p-5 rounded-xl shadow-sm">
                <h2 class="font-bold mb-4 flex items-center gap-2"><i class="fas fa-edit text-blue-500"></i> About Me</h2>
                <form action="/admin/update-about" method="POST" class="space-y-3">
                    <textarea name="content" rows="4" class="w-full p-3 border rounded-lg text-sm" required><%= aboutMe %></textarea>
                    <button type="submit" class="w-full bg-blue-600 text-white py-2 rounded-lg font-bold">Save Bio</button>
                </form>
            </section>

            <section class="bg-white p-5 rounded-xl shadow-sm">
                <h2 class="font-bold mb-4 text-blue-600">Manage Projects</h2>
                <form action="/admin/add-project" method="POST" class="bg-gray-50 p-3 rounded-lg space-y-2 mb-4">
                    <input type="text" name="title" placeholder="Title" required class="w-full p-2 border rounded text-sm">
                    <textarea name="description" placeholder="Short Desc" class="w-full p-2 border rounded text-sm"></textarea>
                    <input type="url" name="link" placeholder="URL" class="w-full p-2 border rounded text-sm">
                    <button type="submit" class="w-full bg-blue-500 text-white py-2 rounded-lg text-sm">+ Add</button>
                </form>
                <div class="max-h-60 overflow-y-auto space-y-2">
                    <% projects.forEach(p => { %>
                    <div class="flex justify-between items-center p-3 border rounded bg-white">
                        <span class="text-sm truncate mr-2"><%= p.title %></span>
                        <form action="/admin/delete-project/<%= p.id %>" method="POST">
                            <button type="submit" class="text-red-400 hover:text-red-600"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                    <% }) %>
                </div>
            </section>

            <section class="bg-white p-5 rounded-xl shadow-sm border-t-4 border-orange-500">
                <h2 class="font-bold mb-4 text-orange-600">Profile & Security</h2>
                <form action="/admin/update-profile" method="POST" class="space-y-3">
                    <input type="text" name="new_username" placeholder="Username" required class="w-full p-2 border rounded text-sm">
                    <input type="password" name="new_password" placeholder="Password" required class="w-full p-2 border rounded text-sm">
                    <input type="text" name="new_secret" placeholder="Secret Code (e.g. 1234)" required class="w-full p-2 border rounded text-sm bg-orange-50">
                    <button type="submit" class="w-full bg-orange-500 text-white py-2 rounded-lg font-bold">Update Profile</button>
                </form>
            </section>

        </div>
    </div>

    <script>
        async function updateStats() {
            try {
                const res = await fetch('/api/stats');
                const data = await res.json();
                document.getElementById('cpu-val').innerText = data.cpu + "%";
                document.getElementById('ram-val').innerText = data.ramUsed + "GB";
                document.getElementById('load-val').innerText = data.sysLoad;
                document.getElementById('visitor-val').innerText = data.visitors;
            } catch (err) { console.error("Stats error"); }
        }
        setInterval(updateStats, 4000);
        updateStats();
    </script>
</body>
</html>
