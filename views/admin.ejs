<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin | Mahmudul Hasan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>tailwind.config = { darkMode: 'class' }</script>
</head>
<body class="bg-gray-100 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen">
    
    <nav class="bg-white dark:bg-gray-800 shadow p-4 sticky top-0 z-50 flex justify-between items-center">
        <h1 class="text-xl font-bold text-blue-600 uppercase">MAHMUDUL ADMIN</h1>
        <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg font-bold text-sm">Logout</a>
    </nav>

    <div class="container mx-auto p-4 md:p-6 space-y-6">
        
        <section class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow">
            <h2 class="font-black text-orange-500 mb-6 uppercase">Photo Gallery & Details</h2>
            
            <form action="/admin/upload-photo" method="POST" enctype="multipart/form-data" class="bg-gray-50 dark:bg-gray-700 p-6 rounded-xl space-y-4 mb-10 border-2 border-dashed dark:border-gray-600">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <input type="file" name="imageFile" required class="p-2 border rounded bg-white dark:bg-gray-800">
                    <input type="text" name="caption" placeholder="Short Title" required class="p-2 border rounded dark:bg-gray-800">
                </div>
                <textarea name="description" placeholder="Long Description (Details about this photo)" class="w-full p-2 border rounded dark:bg-gray-800"></textarea>
                <button type="submit" class="w-full bg-orange-500 text-white py-3 rounded-xl font-bold">+ Upload Photo</button>
            </form>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-h-[500px] overflow-y-auto pr-4">
                <% gallery.forEach(img => { %>
                <div class="flex gap-4 p-4 border dark:border-gray-700 rounded-xl bg-gray-50 dark:bg-gray-800/50">
                    <img src="<%= img.image_url %>" class="w-24 h-24 object-cover rounded-lg">
                    <form action="/admin/update-photo/<%= img.id %>" method="POST" class="flex-grow space-y-2">
                        <input type="text" name="caption" value="<%= img.caption %>" class="w-full text-xs p-1 border rounded dark:bg-gray-800">
                        <textarea name="description" class="w-full text-[10px] p-1 border rounded dark:bg-gray-800" rows="2"><%= img.description %></textarea>
                        <div class="flex justify-between">
                            <button type="submit" class="text-[10px] bg-blue-500 text-white px-2 py-1 rounded">Update</button>
                            <button type="submit" formaction="/admin/delete-photo/<%= img.id %>" class="text-[10px] bg-red-500 text-white px-2 py-1 rounded">Delete</button>
                        </div>
                    </form>
                </div>
                <% }) %>
            </div>
        </section>

        <section class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow border-t-4 border-orange-500">
            <h2 class="font-black text-orange-600 mb-4">Security Settings</h2>
            <form action="/admin/update-profile" method="POST" class="grid grid-cols-1 md:grid-cols-3 gap-3">
                <input type="text" name="new_username" placeholder="Username" required class="p-2 border rounded dark:bg-gray-800">
                <input type="password" name="new_password" placeholder="Password" required class="p-2 border rounded dark:bg-gray-800">
                <input type="text" name="new_secret" placeholder="Secret Code" required class="p-2 border rounded dark:bg-gray-800">
                <button type="submit" class="w-full bg-orange-600 text-white py-2 rounded-lg font-bold">Save</button>
            </form>
        </section>
    </div>
</body>
</html>
