<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | Mahmudul Hasan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>tailwind.config = { darkMode: 'class' }</script>
    <style>
        html { scroll-behavior: smooth; }
        
        /* --- Deep Ash Theme (Eye-Care Light Mode for Admin) --- */
        .light body { 
            background-color: #cbd5e1; 
            color: #0f172a; 
        }
        
        /* Floating Card Style for Admin Panel */
        .light .admin-card, .light .message-item { 
            background-color: #f1f5f9; 
            border: 1px solid #94a3b8; 
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1); 
            transition: all 0.3s ease;
        }
        .light .admin-card:hover { 
            transform: translateY(-4px); 
            box-shadow: 0 20px 35px -5px rgba(0, 0, 0, 0.15); 
        }
        
        /* Message Inbox Hover & Open Style */
        .light .message-item:hover {
            background-color: #e2e8f0;
        }
        .message-body { max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out; }
        .message-item.open .message-body { max-height: 500px; padding-top: 1rem; border-top: 1px solid #94a3b8; margin-top: 1rem; }
        .dark .message-item.open .message-body { border-top-color: #374151; }
        
        /* Message Modal Animation */
        #msg-modal { transition: opacity 0.3s ease; }
    </style>
</head>
<body class="bg-gray-100 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen transition-colors duration-300">
    
    <nav class="bg-white dark:bg-gray-800 shadow p-4 sticky top-0 z-50 flex justify-between items-center border-b dark:border-gray-700">
        <h1 class="text-xl font-bold text-blue-600 italic uppercase tracking-tighter">Mahmudul Admin</h1>
        <div class="flex items-center gap-4">
            <button id="theme-toggle" class="p-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 transition">
                <span id="theme-icon">🌙</span>
            </button>
            <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg font-bold text-xs shadow-md">Logout</a>
        </div>
    </nav>

    <div class="container mx-auto p-4 md:p-6 space-y-12">

        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            
            <div class="admin-card dark:bg-gray-800 p-6 rounded-3xl flex items-center justify-between">
                <div>
                    <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">CPU Usage</p>
                    <h3 class="text-3xl font-black text-gray-800 dark:text-white" id="cpu-stat">0%</h3>
                </div>
                <div class="w-14 h-14 rounded-full bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center">
                    <i class="fas fa-microchip text-blue-600 dark:text-blue-400 text-2xl"></i>
                </div>
            </div>

            <div class="admin-card dark:bg-gray-800 p-6 rounded-3xl flex items-center justify-between">
                <div>
                    <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">RAM Usage</p>
                    <h3 class="text-3xl font-black text-gray-800 dark:text-white" id="ram-stat">0 <span class="text-sm">GB</span></h3>
                </div>
                <div class="w-14 h-14 rounded-full bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center">
                    <i class="fas fa-memory text-purple-600 dark:text-purple-400 text-2xl"></i>
                </div>
            </div>

            <div class="admin-card dark:bg-gray-800 p-6 rounded-3xl flex items-center justify-between">
                <div>
                    <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Total Visitors</p>
                    <h3 class="text-3xl font-black text-gray-800 dark:text-white" id="visitor-stat">...</h3>
                </div>
                <div class="w-14 h-14 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
                    <i class="fas fa-users text-green-600 dark:text-green-400 text-2xl"></i>
                </div>
            </div>

            <div class="admin-card dark:bg-gray-800 p-6 rounded-3xl flex items-center justify-between">
                <div>
                    <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Server Ping</p>
                    <h3 class="text-3xl font-black text-gray-800 dark:text-white" id="ping-stat">0 <span class="text-sm">ms</span></h3>
                </div>
                <div class="w-14 h-14 rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center">
                    <i class="fas fa-server text-orange-600 dark:text-orange-400 text-2xl"></i>
                </div>
            </div>
            
        </section>
        
        <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-sm border dark:border-gray-700">
            <h2 class="font-black mb-4 text-blue-600 uppercase border-b pb-2 tracking-widest">Edit About Me</h2>
            <form action="/admin/update-about" method="POST" class="space-y-4">
                <textarea name="content" rows="4" class="w-full p-4 border rounded-xl dark:bg-gray-900 dark:border-gray-700" required><%= aboutMe %></textarea>
                <button type="submit" class="bg-blue-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-blue-700 transition shadow-md">Update Bio</button>
            </form>
        </section>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-sm border dark:border-gray-700">
                <h2 class="font-bold mb-4 text-purple-600 uppercase border-b pb-2">Education</h2>
                <form action="/admin/add-education" method="POST" class="flex flex-col gap-2 mb-6 text-sm">
                    <input type="text" name="degree" placeholder="Degree" required class="p-2 border rounded dark:bg-gray-900">
                    <input type="text" name="institution" placeholder="Institution" required class="p-2 border rounded dark:bg-gray-900">
                    <input type="text" name="year" placeholder="Year" required class="p-2 border rounded dark:bg-gray-900">
                    <button type="submit" class="bg-purple-600 text-white py-2 rounded-xl font-bold uppercase text-[10px]">Add Education</button>
                </form>
                <div class="space-y-2 max-h-48 overflow-y-auto pr-2">
                    <% education.forEach(e => { %>
                    <div class="flex justify-between items-center p-3 border dark:border-gray-700 rounded-lg bg-gray-50 dark:bg-gray-900/30">
                        <span class="text-xs font-bold"><%= e.degree %></span>
                        <form action="/admin/delete-education/<%= e.id %>" method="POST"><button class="text-red-400 hover:text-red-600"><i class="fas fa-trash"></i></button></form>
                    </div>
                    <% }) %>
                </div>
            </section>

            <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-sm border dark:border-gray-700">
                <h2 class="font-bold mb-4 text-blue-600 uppercase border-b pb-2">Projects & Work</h2>
                <form action="/admin/add-project" method="POST" class="flex flex-col gap-2 mb-6 text-sm">
                    <input type="text" name="title" placeholder="Project Title" required class="p-2 border rounded dark:bg-gray-900">
                    <textarea name="description" placeholder="Short Description" class="p-2 border rounded dark:bg-gray-900"></textarea>
                    <button type="submit" class="bg-blue-500 text-white py-2 rounded-xl font-bold uppercase text-[10px]">Add Project</button>
                </form>
                <div class="space-y-2 max-h-48 overflow-y-auto pr-2">
                    <% projects.forEach(p => { %>
                    <div class="flex justify-between items-center p-3 border dark:border-gray-700 rounded-lg bg-gray-50 dark:bg-gray-900/30">
                        <span class="text-xs font-bold"><%= p.title %></span>
                        <form action="/admin/delete-project/<%= p.id %>" method="POST"><button class="text-red-400 hover:text-red-600"><i class="fas fa-trash"></i></button></form>
                    </div>
                    <% }) %>
                </div>
            </section>
        </div>

        <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-sm border dark:border-gray-700">
            <h2 class="font-black text-green-600 mb-6 uppercase border-b pb-2 tracking-widest">Achievements & Certifications</h2>
            <form action="/admin/add-achievement" method="POST" class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-6">
                <input type="text" name="title" placeholder="Title" required class="p-2 border rounded dark:bg-gray-900">
                <input type="text" name="year" placeholder="Year" required class="p-2 border rounded dark:bg-gray-900">
                <button type="submit" class="bg-green-600 text-white py-2 rounded-xl font-bold uppercase text-xs shadow-md">Add Achievement</button>
            </form>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                <% achievements.forEach(a => { %>
                <div class="flex justify-between items-center p-3 border dark:border-gray-700 rounded-xl bg-gray-50 dark:bg-gray-900/30">
                    <span class="text-xs font-bold"><%= a.title %></span>
                    <form action="/admin/delete-achievement/<%= a.id %>" method="POST"><button class="text-red-400"><i class="fas fa-trash"></i></button></form>
                </div>
                <% }) %>
            </div>
        </section>

        <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-sm border dark:border-gray-700">
            <h2 class="font-black text-orange-500 mb-6 uppercase border-b pb-2 tracking-widest">Photo Gallery Management</h2>
            <form action="/admin/upload-photo" method="POST" enctype="multipart/form-data" class="bg-gray-50 dark:bg-gray-700 p-6 rounded-2xl space-y-4 mb-10 border-2 border-dashed dark:border-gray-600">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <input type="file" name="imageFile" required class="p-2 border rounded bg-white dark:bg-gray-800">
                    <input type="text" name="caption" placeholder="Short Title" required class="p-2 border rounded dark:bg-gray-900">
                </div>
                <textarea name="description" placeholder="Detail Info about this photo..." class="w-full p-2 border rounded dark:bg-gray-900" rows="3"></textarea>
                <button type="submit" class="w-full bg-orange-500 text-white py-3 rounded-xl font-bold uppercase shadow-md hover:bg-orange-600 transition">+ Upload Photo</button>
            </form>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-h-[600px] overflow-y-auto pr-2">
                <% gallery.forEach(img => { %>
                <div class="flex flex-col gap-3 p-4 border dark:border-gray-700 rounded-2xl bg-white dark:bg-gray-900/50 shadow-sm relative group">
                    <img src="<%= img.image_url %>" class="w-full h-32 object-cover rounded-xl border dark:border-gray-700">
                    <form action="/admin/update-photo/<%= img.id %>" method="POST" class="space-y-2">
                        <input type="text" name="caption" value="<%= img.caption %>" class="w-full text-xs font-bold p-2 border rounded dark:bg-gray-900">
                        <textarea name="description" class="w-full text-[10px] p-2 border rounded dark:bg-gray-900" rows="2"><%= img.description %></textarea>
                        <div class="flex justify-between items-center pt-1">
                            <button type="submit" class="bg-blue-600 text-white text-[10px] px-3 py-1.5 rounded-lg font-bold">Update</button>
                            <button type="submit" formaction="/admin/delete-photo/<%= img.id %>" class="bg-red-500 text-white text-[10px] px-3 py-1.5 rounded-lg font-bold">Delete</button>
                        </div>
                    </form>
                </div>
                <% }) %>
            </div>
        </section>

      <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-sm border dark:border-gray-700">
            <h2 class="font-black text-blue-600 mb-6 uppercase tracking-widest border-b pb-2 flex items-center gap-2">
                <i class="fas fa-envelope-open-text text-orange-500"></i> Inbox
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 max-h-[600px] overflow-y-auto pr-2">
                <% if (messages && messages.length > 0) { %>
                    <% messages.forEach((m) => { 
                        
                        // সার্ভার টাইমকে কনভার্ট করে আপনার লোকাল (বাংলাদেশ) টাইম জেনারেট করা হচ্ছে
                        let bdTime = new Date(m.created_at).toLocaleString('en-US', { 
                            timeZone: 'Asia/Dhaka', 
                            month: 'short', 
                            day: 'numeric', 
                            year: 'numeric', 
                            hour: 'numeric', 
                            minute: 'numeric', 
                            hour12: true 
                        });

                    %>
                    <div class="msg-card border dark:border-gray-700 rounded-2xl bg-gray-50 dark:bg-gray-900/30 p-5 flex flex-col justify-between shadow-sm cursor-pointer" 
                        data-name="<%= m.name %>"
                        data-email="<%= m.email %>"
                        data-msg="<%= m.message %>"
                        data-date="<%= bdTime %>"
                        onclick="openMsgModal(this)">
                        
                        <div class="space-y-2">
                            <div class="flex justify-between items-start gap-2">
                                <h4 class="font-bold text-blue-600 dark:text-blue-400 text-sm truncate"><%= m.name %></h4>
                                <span class="text-[10px] text-gray-500 font-bold text-right whitespace-nowrap"><%= bdTime %></span>
                            </div>
                            <p class="text-[11px] text-gray-500 dark:text-gray-400 italic truncate"><%= m.email %></p>
                            <p class="text-xs text-gray-700 dark:text-gray-300 line-clamp-2 mt-2 leading-relaxed"><%= m.message %></p>
                        </div>
                        <div class="flex justify-end mt-4">
                            <form action="/admin/delete-message/<%= m.id %>" method="POST" onclick="event.stopPropagation()">
                                <button type="submit" class="text-red-400 hover:text-red-600 transition"><i class="fas fa-trash-alt"></i></button>
                            </form>
                        </div>
                    </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-center text-gray-400 py-10 italic col-span-full">No messages yet.</p>
                <% } %>
            </div>
        </section>

        <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-sm border-t-8 border-orange-500">
            <h2 class="font-black text-orange-600 mb-4 uppercase tracking-widest border-b pb-2">Admin Security Settings</h2>
            <form action="/admin/update-profile" method="POST" class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <input type="text" name="new_username" placeholder="Username" required class="p-3 border rounded-xl dark:bg-gray-900 dark:border-gray-700">
                <input type="password" name="new_password" placeholder="Password" required class="p-3 border rounded-xl dark:bg-gray-900 dark:border-gray-700">
                <input type="text" name="new_secret" placeholder="Secret Code" required class="p-3 border rounded-xl dark:bg-gray-900 dark:border-gray-700">
                <button type="submit" class="bg-orange-600 text-white py-4 rounded-xl font-black uppercase tracking-widest shadow-xl md:col-span-3 hover:bg-orange-700 transition">Update Credentials</button>
            </form>
        </section>
    </div>

    <div id="msg-modal" class="fixed inset-0 bg-black/80 z-[200] hidden items-center justify-center p-4 backdrop-blur-sm" onclick="closeMsgModal()">
        <div class="max-w-xl w-full bg-white dark:bg-gray-800 rounded-3xl shadow-2xl overflow-hidden transform transition-all scale-95" onclick="event.stopPropagation()">
            <div class="p-8 space-y-6">
                <div class="flex justify-between items-start border-b dark:border-gray-700 pb-4">
                    <div>
                        <h3 id="m-name" class="text-2xl font-black text-blue-600 dark:text-blue-400"></h3>
                        <p id="m-email" class="text-sm text-gray-500 dark:text-gray-400 italic"></p>
                    </div>
                    <span id="m-date" class="text-[10px] font-bold text-gray-400 uppercase tracking-widest"></span>
                </div>
                <div class="min-h-[150px]">
                    <p id="m-text" class="text-gray-700 dark:text-gray-300 leading-relaxed text-lg whitespace-pre-wrap italic"></p>
                </div>
                <div class="flex justify-end pt-4 border-t dark:border-gray-700">
                    <button onclick="closeMsgModal()" class="bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-6 py-2 rounded-xl font-bold uppercase text-xs hover:bg-red-500 hover:text-white transition shadow-md">
                        Close <i class="fas fa-times ml-1"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ডার্ক মোড লজিক
        const themeBtn = document.getElementById('theme-toggle'), themeIcon = document.getElementById('theme-icon'), html = document.documentElement;
        if(localStorage.theme === 'dark') { html.classList.add('dark'); themeIcon.innerText = '☀️'; }
        themeBtn.onclick = () => {
            html.classList.toggle('dark'); const isD = html.classList.contains('dark');
            localStorage.theme = isD ? 'dark' : 'light'; themeIcon.innerText = isD ? '☀️' : '🌙';
        }

        // মেসেজ মডাল ফাংশন
// মেসেজ মডাল ফাংশন (ডাটা অ্যাট্রিবিউট থেকে রিড করবে)
        function openMsgModal(el) {
            const modal = document.getElementById('msg-modal');
            
            // el.getAttribute ব্যবহার করে ডাটা নেওয়া হচ্ছে
            document.getElementById('m-name').innerText = el.getAttribute('data-name');
            document.getElementById('m-email').innerText = el.getAttribute('data-email');
            document.getElementById('m-text').innerText = el.getAttribute('data-msg');
            document.getElementById('m-date').innerText = el.getAttribute('data-date');
            
            modal.classList.replace('hidden', 'flex');
            setTimeout(() => { modal.firstElementChild.classList.replace('scale-95', 'scale-100'); }, 10);
            document.body.style.overflow = 'hidden'; // মডাল ওপেন হলে পেজ স্ক্রল বন্ধ থাকবে
        }

        function closeMsgModal() {
            const modal = document.getElementById('msg-modal');
            modal.firstElementChild.classList.replace('scale-100', 'scale-95');
            setTimeout(() => { modal.classList.replace('flex', 'hidden'); }, 200);
            document.body.style.overflow = 'auto'; 
        }

        // --- REAL-TIME ORIGINAL DATA FETCHING LOGIC ---
        async function fetchRealTimeStats() {
            try {
                const startTime = Date.now();
                // ব্যাকএন্ড থেকে আসল হার্ডওয়্যার ডাটা রিকোয়েস্ট
                const response = await fetch('/admin/api/server-stats');
                const data = await response.json();
                
                // রিয়েল-টাইম সার্ভার পিং (Request to Response time)
                const ping = Date.now() - startTime; 

                // আসল ডাটাগুলো বক্সে সেট করা
                document.getElementById('cpu-stat').innerText = data.cpu + '%';
                document.getElementById('ram-stat').innerHTML = data.ram + ' <span class="text-sm">GB</span>';
                document.getElementById('ping-stat').innerHTML = ping + ' <span class="text-sm">ms</span>';
                document.getElementById('visitor-stat').innerText = data.visitors; // যদি ব্যাকএন্ড থেকে পাঠানো হয়
            } catch (error) {
                console.error("Failed to fetch real-time server stats.");
            }
        }
        
        // প্রতি ৩ সেকেন্ড পর পর আসল ডাটা আপডেট হবে
        setInterval(fetchRealTimeStats, 3000);
        fetchRealTimeStats(); // পেজ লোড হলেই সাথে সাথে একবার কল হবে
    </script>
</body>
</html>
