<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin | Mahmudul Hasan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>tailwind.config = { darkMode: 'class' }</script>
</head>
<body class="bg-gray-100 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen">
    <nav class="bg-white dark:bg-gray-800 shadow p-4 sticky top-0 z-50 flex justify-between items-center">
        <h1 class="text-xl font-bold text-blue-600">MAHMUDUL ADMIN</h1>
        <div class="flex items-center gap-4">
            <button id="theme-toggle" class="p-2 rounded-lg bg-gray-200 dark:bg-gray-700"><span id="theme-icon">🌙</span></button>
            <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg font-bold">Logout</a>
        </div>
    </nav>

    <div class="container mx-auto p-4 space-y-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow text-center"><p class="text-xs text-gray-500 uppercase">Visitors</p><h3 id="visitor-val" class="text-2xl font-bold text-purple-600">0</h3></div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow text-center"><p class="text-xs text-gray-500 uppercase">CPU</p><h3 id="cpu-val" class="text-2xl font-bold text-blue-600">--</h3></div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow text-center"><p class="text-xs text-gray-500 uppercase">RAM</p><h3 id="ram-val" class="text-2xl font-bold text-green-600">--</h3></div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow text-center"><p class="text-xs text-gray-500 uppercase">Load</p><h3 id="load-val" class="text-2xl font-bold text-orange-600">--</h3></div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <section class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow">
                <h2 class="font-bold mb-4 text-orange-500">Manage Gallery</h2>
                <form action="/admin/add-photo" method="POST" class="space-y-3 mb-6 bg-gray-50 dark:bg-gray-700 p-4 rounded-xl">
                    <input type="text" name="image_url" placeholder="Paste Image Link (URL)" required class="w-full p-2 border rounded dark:bg-gray-800">
                    <input type="text" name="caption" placeholder="Short Caption" class="w-full p-2 border rounded dark:bg-gray-800">
                    <button type="submit" class="w-full bg-orange-500 text-white py-2 rounded-lg font-bold">+ Upload to Gallery</button>
                </form>
                <div class="grid grid-cols-3 gap-2 max-h-60 overflow-y-auto">
                    <% gallery.forEach(img => { %>
                    <div class="relative group">
                        <img src="<%= img.image_url %>" class="w-full h-20 object-cover rounded">
                        <form action="/admin/delete-photo/<%= img.id %>" method="POST" class="absolute top-1 right-1">
                            <button class="bg-red-500 text-white p-1 rounded-full text-[10px]"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                    <% }) %>
                </div>
            </section>

            <section class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow">
                <h2 class="font-bold mb-4">Update About</h2>
                <form action="/admin/update-about" method="POST" class="space-y-3">
                    <textarea name="content" rows="3" class="w-full p-2 border rounded dark:bg-gray-800"><%= aboutMe %></textarea>
                    <button type="submit" class="w-full bg-blue-600 text-white py-2 rounded-lg">Update Bio</button>
                </form>
            </section>

            <section class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow">
                <h2 class="font-bold mb-4 text-blue-600">Projects</h2>
                <form action="/admin/add-project" method="POST" class="space-y-2 mb-4">
                    <input type="text" name="title" placeholder="Title" required class="w-full p-2 border rounded dark:bg-gray-800">
                    <button type="submit" class="w-full bg-blue-500 text-white py-2 rounded-lg">Add Project</button>
                </form>
                <% projects.forEach(p => { %>
                    <div class="flex justify-between p-2 border-b dark:border-gray-700"><span><%= p.title %></span><form action="/admin/delete-project/<%= p.id %>" method="POST"><button class="text-red-500"><i class="fas fa-trash"></i></button></form></div>
                <% }) %>
            </section>

            <section class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow border-t-4 border-orange-500">
                <h2 class="font-bold mb-4 text-orange-600">Profile & Security</h2>
                <form action="/admin/update-profile" method="POST" class="space-y-3">
                    <input type="text" name="new_username" placeholder="Username" required class="w-full p-2 border rounded dark:bg-gray-800">
                    <input type="password" name="new_password" placeholder="Password" required class="w-full p-2 border rounded dark:bg-gray-800">
                    <input type="text" name="new_secret" placeholder="Secret Code" required class="w-full p-2 border rounded dark:bg-gray-800">
                    <button type="submit" class="w-full bg-orange-500 text-white py-2 rounded-lg font-bold">Update Profile</button>
                </form>
            </section>
        </div>
    </div>

    <script>
        async function fetchStats() {
            try {
                const res = await fetch('/api/stats');
                const data = await res.json();
                document.getElementById('cpu-val').innerText = data.cpu + "%";
                document.getElementById('ram-val').innerText = data.ramUsed + "GB";
                document.getElementById('load-val').innerText = data.sysLoad;
                document.getElementById('visitor-val').innerText = data.visitors;
            } catch (err) {}
        }
        setInterval(fetchStats, 4000); fetchStats();
        const themeBtn = document.getElementById('theme-toggle'), html = document.documentElement;
        if(localStorage.theme === 'dark') { html.classList.add('dark'); document.getElementById('theme-icon').innerText = '☀️'; }
        themeBtn.onclick = () => { html.classList.toggle('dark'); const isD = html.classList.contains('dark'); localStorage.theme = isD ? 'dark' : 'light'; document.getElementById('theme-icon').innerText = isD ? '☀️' : '🌙'; }
    </script>
</body>
</html>
