<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | Mahmudul Hasan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>tailwind.config = { darkMode: 'class' }</script>
</head>
<body class="bg-gray-100 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen transition-colors duration-300">
    
    <nav class="bg-white dark:bg-gray-800 shadow p-4 sticky top-0 z-50 flex justify-between items-center">
        <h1 class="text-xl font-bold text-blue-600">MAHMUDUL ADMIN</h1>
        <div class="flex items-center gap-3">
            <button id="theme-toggle" class="p-2 rounded-lg bg-gray-200 dark:bg-gray-700">🌙</button>
            <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg font-bold">Logout</a>
        </div>
    </nav>

    <div class="container mx-auto p-4 md:p-6 space-y-12">
        
        <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow">
            <h2 class="font-black mb-4 text-blue-600 uppercase tracking-widest border-b pb-2">Edit About Me</h2>
            <form action="/admin/update-about" method="POST" class="space-y-4">
                <textarea name="content" rows="4" class="w-full p-4 border rounded-xl dark:bg-gray-900 dark:border-gray-700"><%= aboutMe %></textarea>
                <button type="submit" class="bg-blue-600 text-white px-8 py-3 rounded-xl font-bold">Update Bio</button>
            </form>
        </section>

        <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow">
            <h2 class="font-bold mb-4 text-purple-600 uppercase tracking-widest border-b pb-2">Education</h2>
            <form action="/admin/add-education" method="POST" class="grid grid-cols-1 md:grid-cols-4 gap-3 mb-6 text-sm">
                <input type="text" name="degree" placeholder="Degree" required class="p-2 border rounded dark:bg-gray-900">
                <input type="text" name="institution" placeholder="Institution" required class="p-2 border rounded dark:bg-gray-900">
                <input type="text" name="year" placeholder="Year" required class="p-2 border rounded dark:bg-gray-900">
                <button type="submit" class="bg-purple-600 text-white rounded font-bold">Add</button>
            </form>
            <div class="space-y-2">
                <% education.forEach(e => { %>
                <div class="flex justify-between p-2 border-b dark:border-gray-700"><span><%= e.degree %></span><form action="/admin/delete-education/<%= e.id %>" method="POST"><button class="text-red-500"><i class="fas fa-trash text-xs"></i></button></form></div>
                <% }) %>
            </div>
        </section>

        <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow">
            <h2 class="font-bold mb-4 text-blue-600 uppercase tracking-widest border-b pb-2">Projects & Work</h2>
            <form action="/admin/add-project" method="POST" class="flex flex-col gap-2 mb-6">
                <input type="text" name="title" placeholder="Project Name" required class="p-2 border rounded dark:bg-gray-900">
                <textarea name="description" placeholder="Description" class="p-2 border rounded dark:bg-gray-900 text-sm"></textarea>
                <button type="submit" class="bg-blue-500 text-white py-2 rounded-xl font-bold">Add Project</button>
            </form>
            <div class="space-y-2">
                <% projects.forEach(p => { %>
                <div class="flex justify-between p-2 border-b dark:border-gray-700"><span><%= p.title %></span><form action="/admin/delete-project/<%= p.id %>" method="POST"><button class="text-red-500"><i class="fas fa-trash text-xs"></i></button></form></div>
                <% }) %>
            </div>
        </section>

        <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow">
            <h2 class="font-bold mb-4 text-green-600 uppercase tracking-widest border-b pb-2">Achievements</h2>
            <form action="/admin/add-achievement" method="POST" class="flex gap-2 mb-6">
                <input type="text" name="title" placeholder="Achievement Name" required class="flex-grow p-2 border rounded dark:bg-gray-900">
                <input type="text" name="year" placeholder="Year" class="p-2 border rounded dark:bg-gray-900">
                <button type="submit" class="bg-green-600 text-white px-4 rounded font-bold">Add</button>
            </form>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                <% achievements.forEach(a => { %>
                <div class="flex justify-between p-2 border rounded dark:border-gray-700"><span><%= a.title %></span><form action="/admin/delete-achievement/<%= a.id %>" method="POST"><button class="text-red-400"><i class="fas fa-trash text-xs"></i></button></form></div>
                <% }) %>
            </div>
        </section>

        <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow">
            <h2 class="font-black text-orange-500 mb-6 uppercase tracking-widest border-b pb-2">Photo Gallery</h2>
            <form action="/admin/upload-photo" method="POST" enctype="multipart/form-data" class="bg-gray-50 dark:bg-gray-700 p-6 rounded-2xl space-y-4 mb-10">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <input type="file" name="imageFile" required class="p-2 border rounded bg-white dark:bg-gray-900">
                    <input type="text" name="caption" placeholder="Caption (Short Title)" required class="p-2 border rounded dark:bg-gray-900">
                </div>
                <textarea name="description" placeholder="Detail Description (Write here about the photo)" class="w-full p-2 border rounded dark:bg-gray-900" rows="3"></textarea>
                <button type="submit" class="w-full bg-orange-500 text-white py-3 rounded-xl font-bold uppercase">+ Upload</button>
            </form>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-h-[600px] overflow-y-auto pr-2">
                <% gallery.forEach(img => { %>
                <div class="flex gap-4 p-4 border dark:border-gray-700 rounded-2xl bg-white dark:bg-gray-900/50">
                    <img src="<%= img.image_url %>" class="w-20 h-20 object-cover rounded-xl">
                    <form action="/admin/update-photo/<%= img.id %>" method="POST" class="flex-grow space-y-2">
                        <input type="text" name="caption" value="<%= img.caption %>" class="w-full text-xs font-bold p-1 border rounded dark:bg-gray-900">
                        <textarea name="description" class="w-full text-[10px] p-1 border rounded dark:bg-gray-900" rows="2" placeholder="Detail write here..."><%= img.description %></textarea>
                        <div class="flex justify-between">
                            <button type="submit" class="text-[10px] bg-blue-500 text-white px-2 py-1 rounded">Save Changes</button>
                            <button type="submit" formaction="/admin/delete-photo/<%= img.id %>" class="text-[10px] bg-red-500 text-white px-2 py-1 rounded">Delete</button>
                        </div>
                    </form>
                </div>
                <% }) %>
            </div>
        </section>

        <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow border-t-8 border-orange-500">
            <h2 class="font-black text-orange-600 mb-6 uppercase tracking-widest">Admin Account Settings</h2>
            <form action="/admin/update-profile" method="POST" class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="flex flex-col gap-1">
                    <label class="text-xs text-gray-500 ml-1 uppercase">New Username</label>
                    <input type="text" name="new_username" placeholder="Username" required class="p-3 border rounded-xl dark:bg-gray-900 dark:border-gray-700">
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-xs text-gray-500 ml-1 uppercase">New Password</label>
                    <input type="password" name="new_password" placeholder="Password" required class="p-3 border rounded-xl dark:bg-gray-900 dark:border-gray-700">
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-xs text-gray-500 ml-1 uppercase">Secret Recovery Code</label>
                    <input type="text" name="new_secret" placeholder="Secret Code" required class="p-3 border rounded-xl dark:bg-gray-900 dark:border-gray-700">
                </div>
                <button type="submit" class="bg-orange-600 text-white py-3 rounded-xl font-bold uppercase shadow-lg md:col-span-3 mt-2">Update Credentials</button>
            </form>
        </section>
    </div>

    <script>
        const themeBtn = document.getElementById('theme-toggle'), html = document.documentElement;
        if(localStorage.theme === 'dark') html.classList.add('dark');
        themeBtn.onclick = () => { html.classList.toggle('dark'); localStorage.theme = html.classList.contains('dark') ? 'dark' : 'light'; }
    </script>
</body>
</html>
