<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-100 font-sans">

    <nav class="bg-white shadow-lg p-4 sticky top-0 z-50">
        <div class="container mx-auto flex justify-between items-center">
            <h1 class="text-2xl font-bold text-blue-600 italic">Portfolio Admin</h1>
            <div class="flex items-center gap-4">
                <span class="text-gray-600 hidden md:block">Welcome, <b><%= currentAdmin %></b></span>
                <a href="/" target="_blank" class="bg-blue-100 text-blue-600 px-4 py-2 rounded-lg hover:bg-blue-200 transition">View Site</a>
                <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600 transition">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mx-auto p-6">
        
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8 text-center">
            <div class="bg-white p-4 rounded-xl shadow">
                <p class="text-gray-500 text-sm">CPU Usage</p>
                <h3 id="cpu-val" class="text-xl font-bold text-blue-600">-- %</h3>
            </div>
            <div class="bg-white p-4 rounded-xl shadow">
                <p class="text-gray-500 text-sm">RAM Used</p>
                <h3 id="ram-val" class="text-xl font-bold text-green-600">-- GB</h3>
            </div>
            <div class="bg-white p-4 rounded-xl shadow">
                <p class="text-gray-500 text-sm">Sys Load</p>
                <h3 id="load-val" class="text-xl font-bold text-orange-600">--</h3>
            </div>
            <div class="bg-white p-4 rounded-xl shadow">
                <p class="text-gray-500 text-sm">Visitors</p>
                <h3 class="text-xl font-bold text-purple-600">Live</h3>
            </div>
        </div>

        <section class="bg-white p-6 rounded-xl shadow-md mb-8">
            <h2 class="text-lg font-bold mb-4 border-b pb-2"><i class="fas fa-user-edit mr-2"></i>Update Bio</h2>
            <form action="/admin/update-about" method="POST" class="flex flex-col gap-3">
                <textarea name="content" rows="3" class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400" required><%= aboutMe %></textarea>
                <button type="submit" class="bg-blue-600 text-white py-2 px-6 rounded-lg w-fit hover:bg-blue-700 transition">Update About Me</button>
            </form>
        </section>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            
            <section class="bg-white p-6 rounded-xl shadow-md">
                <h2 class="text-lg font-bold mb-4 border-b pb-2 text-blue-600">Manage Projects</h2>
                <form action="/admin/add-project" method="POST" class="mb-6 bg-gray-50 p-4 rounded-lg flex flex-col gap-3">
                    <input type="text" name="title" placeholder="Project Title" required class="p-2 border rounded">
                    <textarea name="description" placeholder="Short Description" class="p-2 border rounded"></textarea>
                    <input type="url" name="link" placeholder="Link (Optional)" class="p-2 border rounded">
                    <button type="submit" class="bg-blue-500 text-white py-2 rounded-lg hover:bg-blue-600">+ Add Project</button>
                </form>

                <div class="space-y-3">
                    <% projects.forEach(p => { %>
                        <div class="flex justify-between items-center p-3 border rounded-lg bg-white hover:bg-gray-50">
                            <div>
                                <h4 class="font-bold"><%= p.title %></h4>
                                <p class="text-xs text-gray-500"><%= p.link %></p>
                            </div>
                            <form action="/admin/delete-project/<%= p.id %>" method="POST" onsubmit="return confirm('Delete this project?')">
                                <button type="submit" class="text-red-500 hover:text-red-700 p-2"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                    <% }) %>
                </div>
            </section>

            <section class="bg-white p-6 rounded-xl shadow-md">
                <h2 class="text-lg font-bold mb-4 border-b pb-2 text-purple-600">Manage Education</h2>
                <form action="/admin/add-education" method="POST" class="mb-6 bg-gray-50 p-4 rounded-lg flex flex-col gap-3">
                    <input type="text" name="degree" placeholder="Degree (e.g. B.Sc)" required class="p-2 border rounded">
                    <input type="text" name="institution" placeholder="University Name" required class="p-2 border rounded">
                    <input type="text" name="year" placeholder="Year (e.g. 2022-2026)" required class="p-2 border rounded">
                    <button type="submit" class="bg-purple-500 text-white py-2 rounded-lg hover:bg-purple-600">+ Add Education</button>
                </form>

                <div class="space-y-3">
                    <% education.forEach(e => { %>
                        <div class="flex justify-between items-center p-3 border rounded-lg bg-white">
                            <div>
                                <h4 class="font-bold"><%= e.degree %></h4>
                                <p class="text-xs text-gray-500"><%= e.institution %> (<%= e.year %>)</p>
                            </div>
                            <form action="/admin/delete-education/<%= e.id %>" method="POST" onsubmit="return confirm('Delete this education?')">
                                <button type="submit" class="text-red-500 hover:text-red-700 p-2"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                    <% }) %>
                </div>
            </section>

            <section class="bg-white p-6 rounded-xl shadow-md">
                <h2 class="text-lg font-bold mb-4 border-b pb-2 text-green-600">Manage Achievements</h2>
                <form action="/admin/add-achievement" method="POST" class="mb-6 bg-gray-50 p-4 rounded-lg flex flex-col gap-3">
                    <input type="text" name="title" placeholder="Achievement Name" required class="p-2 border rounded">
                    <input type="text" name="year" placeholder="Year" required class="p-2 border rounded">
                    <button type="submit" class="bg-green-500 text-white py-2 rounded-lg hover:bg-green-600">+ Add Achievement</button>
                </form>

                <div class="space-y-3">
                    <% achievements.forEach(a => { %>
                        <div class="flex justify-between items-center p-3 border rounded-lg bg-white">
                            <div>
                                <h4 class="font-bold"><%= a.title %></h4>
                                <p class="text-xs text-gray-500"><%= a.year %></p>
                            </div>
                            <form action="/admin/delete-achievement/<%= a.id %>" method="POST" onsubmit="return confirm('Delete this achievement?')">
                                <button type="submit" class="text-red-500 hover:text-red-700 p-2"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                    <% }) %>
                </div>
            </section>

            <section class="bg-white p-6 rounded-xl shadow-md border-t-4 border-orange-500">
                <h2 class="text-lg font-bold mb-4 border-b pb-2 text-orange-600">Account Credentials</h2>
                <form action="/admin/update-profile" method="POST" class="flex flex-col gap-3">
                    <label class="text-sm text-gray-500">New Username</label>
                    <input type="text" name="new_username" placeholder="Change Username" required class="p-2 border rounded">
                    <label class="text-sm text-gray-500">New Password</label>
                    <input type="password" name="new_password" placeholder="Change Password" required class="p-3 border rounded-lg bg-gray-50 focus:bg-white">
                    <button type="submit" class="bg-orange-500 text-white font-bold py-3 rounded-lg hover:bg-orange-600 transition">Update Credentials</button>
                </form>
            </section>

        </div>
    </div>

    <script>
        async function updateStats() {
            try {
                const res = await fetch('/api/stats');
                const data = await res.json();
                document.getElementById('cpu-val').innerText = data.cpu + " %";
                document.getElementById('ram-val').innerText = data.ramUsed + " / " + data.ramTotal + " GB";
                document.getElementById('load-val').innerText = data.sysLoad;
            } catch (err) { console.error("Stats fail"); }
        }
        setInterval(updateStats, 3000);
        updateStats();
    </script>
</body>
</html>
