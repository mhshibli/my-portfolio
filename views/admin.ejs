<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin | Mahmudul Hasan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>tailwind.config = { darkMode: 'class' }</script>
</head>
<body class="bg-gray-100 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen">
    
    <nav class="bg-white dark:bg-gray-800 shadow p-4 sticky top-0 z-50 flex justify-between items-center border-b dark:border-gray-700">
        <h1 class="text-xl font-bold text-blue-600 uppercase italic">MAHMUDUL ADMIN</h1>
        <div class="flex items-center gap-4">
            <a href="/" target="_blank" class="text-xs font-bold text-blue-500 uppercase">View Site</a>
            <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg font-bold text-sm">Logout</a>
        </div>
    </nav>

    <div class="container mx-auto p-4 md:p-6 space-y-8">
        
        <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-sm">
            <h2 class="font-black text-orange-500 mb-6 uppercase tracking-widest border-b pb-2">Photo Gallery Management</h2>
            <form action="/admin/upload-photo" method="POST" enctype="multipart/form-data" class="bg-gray-50 dark:bg-gray-700 p-6 rounded-2xl space-y-4 mb-10 border-2 border-dashed dark:border-gray-600">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <input type="file" name="imageFile" required class="p-2 border rounded bg-white dark:bg-gray-800">
                    <input type="text" name="caption" placeholder="Short Caption (e.g. My Thesis)" required class="p-2 border rounded dark:bg-gray-800">
                </div>
                <textarea name="description" placeholder="Long Description (Details about this photo)" class="w-full p-2 border rounded dark:bg-gray-800" rows="3"></textarea>
                <button type="submit" class="w-full bg-orange-500 text-white py-3 rounded-xl font-bold uppercase tracking-widest">+ Upload Photo</button>
            </form>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-h-[600px] overflow-y-auto pr-2">
                <% gallery.forEach(img => { %>
                <div class="flex gap-4 p-4 border dark:border-gray-700 rounded-2xl bg-white dark:bg-gray-900/50 shadow-sm">
                    <img src="<%= img.image_url %>" class="w-24 h-24 object-cover rounded-xl border dark:border-gray-700">
                    <form action="/admin/update-photo/<%= img.id %>" method="POST" class="flex-grow space-y-2">
                        <input type="text" name="caption" value="<%= img.caption %>" class="w-full text-sm font-bold p-2 border rounded dark:bg-gray-800">
                        <textarea name="description" class="w-full text-xs p-2 border rounded dark:bg-gray-800" rows="2"><%= img.description %></textarea>
                        <div class="flex justify-between items-center pt-1">
                            <button type="submit" class="bg-blue-600 text-white text-xs px-3 py-1.5 rounded-lg hover:bg-blue-700 transition">Update</button>
                            <button type="submit" formaction="/admin/delete-photo/<%= img.id %>" class="bg-red-50 text-red-600 text-xs px-3 py-1.5 rounded-lg hover:bg-red-600 hover:text-white transition">Delete</button>
                        </div>
                    </form>
                </div>
                <% }) %>
            </div>
        </section>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-sm border dark:border-gray-700">
                <h2 class="font-bold mb-4 text-blue-600 uppercase">Manage Projects</h2>
                <form action="/admin/add-project" method="POST" class="flex flex-col gap-2 mb-6">
                    <input type="text" name="title" placeholder="Project Name" required class="p-2 border rounded dark:bg-gray-800">
                    <textarea name="description" placeholder="Description" class="p-2 border rounded dark:bg-gray-800 text-sm"></textarea>
                    <button type="submit" class="bg-blue-500 text-white py-2 rounded-xl font-bold uppercase text-xs">Add Project</button>
                </form>
                <div class="space-y-2 max-h-48 overflow-y-auto pr-2">
                    <% projects.forEach(p => { %>
                    <div class="flex justify-between items-center p-3 border dark:border-gray-700 rounded-xl bg-gray-50 dark:bg-gray-900/30">
                        <span class="text-xs font-bold"><%= p.title %></span>
                        <form action="/admin/delete-project/<%= p.id %>" method="POST"><button class="text-red-400"><i class="fas fa-trash"></i></button></form>
                    </div>
                    <% }) %>
                </div>
            </section>

            <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-sm border dark:border-gray-700">
                <h2 class="font-bold mb-4 text-purple-600 uppercase">Manage Education</h2>
                <form action="/admin/add-education" method="POST" class="flex flex-col gap-2 mb-6 text-sm">
                    <input type="text" name="degree" placeholder="Degree" required class="p-2 border rounded dark:bg-gray-800">
                    <input type="text" name="institution" placeholder="Institution" required class="p-2 border rounded dark:bg-gray-800">
                    <input type="text" name="year" placeholder="Year" required class="p-2 border rounded dark:bg-gray-800">
                    <button type="submit" class="bg-purple-600 text-white py-2 rounded-xl font-bold uppercase text-xs">Add Education</button>
                </form>
            </section>
        </div>

        <section class="bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-sm border-t-8 border-orange-500">
            <h2 class="font-black text-orange-600 mb-4 uppercase">Security & Profile</h2>
            <form action="/admin/update-profile" method="POST" class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <input type="text" name="new_username" placeholder="New Username" required class="p-3 border rounded-xl dark:bg-gray-800">
                <input type="password" name="new_password" placeholder="New Password" required class="p-3 border rounded-xl dark:bg-gray-800">
                <input type="text" name="new_secret" placeholder="Secret Answer" required class="p-3 border rounded-xl dark:bg-gray-800">
                <button type="submit" class="bg-orange-600 text-white py-3 rounded-xl font-bold uppercase tracking-widest shadow-lg">Save Profile</button>
            </form>
        </section>
    </div>

    <script>
        async function fetchStats() {
            try {
                const res = await fetch('/api/stats');
                const data = await res.json();
                // If you have status val elements, update them here
            } catch (e) {}
        }
        setInterval(fetchStats, 5000); fetchStats();

        const themeBtn = document.getElementById('theme-toggle'), html = document.documentElement;
        if(localStorage.theme === 'dark') html.classList.add('dark');
        themeBtn.onclick = () => {
            html.classList.toggle('dark'); const isD = html.classList.contains('dark');
            localStorage.theme = isD ? 'dark' : 'light';
        }
    </script>
</body>
</html>
