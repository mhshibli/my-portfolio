<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-100 min-h-screen">

    <nav class="bg-white shadow p-4 sticky top-0 z-50">
        <div class="container mx-auto flex justify-between items-center">
            <h1 class="text-xl font-bold text-blue-600 italic">Admin Dashboard</h1>
            <div class="flex items-center gap-4">
                <a href="/" target="_blank" class="text-blue-500 font-bold">Site</a>
                <a href="/logout" class="bg-red-500 text-white px-3 py-2 rounded-lg">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mx-auto p-4 md:p-6 space-y-8">
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-white p-4 rounded-xl shadow text-center">
                <p class="text-xs text-gray-500">CPU</p>
                <h3 id="cpu-val" class="font-bold text-blue-600">--</h3>
            </div>
            <div class="bg-white p-4 rounded-xl shadow text-center">
                <p class="text-xs text-gray-500">RAM</p>
                <h3 id="ram-val" class="font-bold text-green-600">--</h3>
            </div>
            <div class="bg-white p-4 rounded-xl shadow text-center">
                <p class="text-xs text-gray-500">LOAD</p>
                <h3 id="load-val" class="font-bold text-orange-600">--</h3>
            </div>
            <div class="bg-white p-4 rounded-xl shadow text-center">
                <p class="text-xs text-gray-500">VISITORS</p>
                <h3 id="visitor-val" class="font-bold text-purple-600">0</h3>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            
            <div class="space-y-8">
                <section class="bg-white p-5 rounded-xl shadow">
                    <h2 class="font-bold mb-4">Bio</h2>
                    <form action="/admin/update-about" method="POST" class="space-y-3">
                        <textarea name="content" rows="3" class="w-full p-2 border rounded" required><%= aboutMe %></textarea>
                        <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded">Update</button>
                    </form>
                </section>

                <section class="bg-white p-5 rounded-xl shadow">
                    <h2 class="font-bold mb-4 text-blue-600">Projects</h2>
                    <form action="/admin/add-project" method="POST" class="space-y-2 mb-4 bg-gray-50 p-3 rounded">
                        <input type="text" name="title" placeholder="Title" required class="w-full p-2 border rounded">
                        <textarea name="description" placeholder="Short Desc" class="w-full p-2 border rounded"></textarea>
                        <input type="url" name="link" placeholder="Link" class="w-full p-2 border rounded">
                        <button type="submit" class="w-full bg-blue-500 text-white py-2 rounded">+ Add Project</button>
                    </form>
                    <% projects.forEach(p => { %>
                    <div class="flex justify-between p-2 border-b">
                        <span><%= p.title %></span>
                        <form action="/admin/delete-project/<%= p.id %>" method="POST"><button class="text-red-500"><i class="fas fa-trash"></i></button></form>
                    </div>
                    <% }) %>
                </section>
            </div>

            <div class="space-y-8">
                <section class="bg-white p-5 rounded-xl shadow">
                    <h2 class="font-bold mb-4 text-purple-600">Education</h2>
                    <form action="/admin/add-education" method="POST" class="space-y-2 mb-4 bg-gray-50 p-3 rounded">
                        <input type="text" name="degree" placeholder="Degree" required class="w-full p-2 border rounded">
                        <input type="text" name="institution" placeholder="Institution" required class="w-full p-2 border rounded">
                        <input type="text" name="year" placeholder="Year" required class="w-full p-2 border rounded">
                        <button type="submit" class="w-full bg-purple-500 text-white py-2 rounded">+ Add Education</button>
                    </form>
                    <% education.forEach(e => { %>
                    <div class="flex justify-between p-2 border-b text-sm">
                        <span><%= e.degree %></span>
                        <form action="/admin/delete-education/<%= e.id %>" method="POST"><button class="text-red-500"><i class="fas fa-trash"></i></button></form>
                    </div>
                    <% }) %>
                </section>

                <section class="bg-white p-5 rounded-xl shadow">
                    <h2 class="font-bold mb-4 text-green-600">Achievements</h2>
                    <form action="/admin/add-achievement" method="POST" class="space-y-2 mb-4 bg-gray-50 p-3 rounded">
                        <input type="text" name="title" placeholder="Achievement/Cert Title" required class="w-full p-2 border rounded">
                        <input type="text" name="year" placeholder="Year" required class="w-full p-2 border rounded">
                        <button type="submit" class="w-full bg-green-500 text-white py-2 rounded">+ Add Achievement</button>
                    </form>
                    <% achievements.forEach(a => { %>
                    <div class="flex justify-between p-2 border-b text-sm">
                        <span><%= a.title %></span>
                        <form action="/admin/delete-achievement/<%= a.id %>" method="POST"><button class="text-red-500"><i class="fas fa-trash"></i></button></form>
                    </div>
                    <% }) %>
                </section>
            </div>

            <section class="bg-white p-5 rounded-xl shadow border-t-4 border-orange-500 lg:col-span-2">
                <h2 class="font-bold mb-4 text-orange-600">Profile & Security Settings</h2>
                <form action="/admin/update-profile" method="POST" class="grid grid-cols-1 md:grid-cols-3 gap-3">
                    <input type="text" name="new_username" placeholder="Username" required class="p-2 border rounded">
                    <input type="password" name="new_password" placeholder="Password" required class="p-2 border rounded">
                    <input type="text" name="new_secret" placeholder="Secret Code" required class="p-2 border rounded">
                    <button type="submit" class="bg-orange-500 text-white py-2 rounded font-bold">Update Profile</button>
                </form>
            </section>
        </div>
    </div>

    <script>
        async function updateStats() {
            try {
                const res = await fetch('/api/stats');
                const data = await res.json();
                document.getElementById('cpu-val').innerText = data.cpu + "%";
                document.getElementById('ram-val').innerText = data.ramUsed + "GB";
                document.getElementById('load-val').innerText = data.sysLoad;
                document.getElementById('visitor-val').innerText = data.visitors;
            } catch (err) { console.error("Stats fail"); }
        }
        setInterval(updateStats, 4000);
        updateStats();
    </script>
</body>
</html>
